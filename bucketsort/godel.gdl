PREDICATE bucket_sort(NONVAR, NONVAR) OF
  List, Int
  SUCH THAT
  bucket_sort([], _, []).
  bucket_sort([H|T], MaxVal, Result) :-
    bucket_sort(T, MaxVal, RestResult),
    insert_sorted(H, RestResult, Result).
  insert_sorted(X, [], [X]).
  insert_sorted(X, [H|T], [X, H|T]) :- X =< H.
  insert_sorted(X, [H|T], [H|Rest]) :-
    X > H,
    insert_sorted(X, T, Rest).