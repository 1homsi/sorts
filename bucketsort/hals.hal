DECLARE RESULT(100) FIXED;
DECLARE BUCKETS(10) FIXED;
DECLARE ARR(6) FIXED INITIAL(5,2,8,1,9,3);
DECLARE (I,J,K) FIXED;
DO I = 0 TO 9;
  BUCKETS(I) = 0;
END;
DO I = 0 TO 5;
  BUCKETS(ARR(I)+1) = ARR(I);
END;
K = 0;
DO J = 0 TO 9;
  IF BUCKETS(J) > 0 THEN DO;
    RESULT(K+1) = J;
    K = K + 1;
  END;
END;
DISPLAY RESULT;