BEGIN
  INTEGER ARRAY BUCKETS[0:9];
  INTEGER I, NUM;
  FOR I := 0 STEP 1 UNTIL 9 DO BUCKETS[I] := 0;
  BUCKETS[0] := 1; BUCKETS[1] := 1; BUCKETS[2] := 1;
  BUCKETS[3] := 1; BUCKETS[5] := 1; BUCKETS[8] := 1;
  BUCKETS[9] := 1;
  FOR I := 0 STEP 1 UNTIL 9 DO BEGIN
    IF BUCKETS[I] > 0 THEN
      WRITE(I, " ")
  END
END