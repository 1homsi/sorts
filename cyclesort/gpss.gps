SIMULATE
GENERATE 1
  TRANSFER ,ENDSIM
PROCEDURE CYCLESORT
  ASSIGN X1=6
  ASSIGN X2=0
MAINLOOP TEST GE X2,X1,ENDMAIN
  ASSIGN X3=0
  ASSIGN X4=0
COUNTLOOP TEST GE X4,X1,ENDCOUNT
  TEST EQ X4,X2,SKIP
  TEST LE TABLE$(X4),TABLE$(X2),SKIP
  ASSIGN X3=X3+1
SKIP TRANSFER ,NEXT
  ASSIGN X4=X4+1
COUNTLOOP TRANSFER ,COUNTLOOP
ENDCOUNT TRANSFER ,MAINLOOP
ENDMAIN TERMINATE
