PREFIX ex: <http://example.org/>

SELECT ?sorted
WHERE {
  VALUES (?val) { (5) (4) (3) (2) (1) }
  {
    SELECT ?val (COUNT(?smaller) AS ?pos)
    WHERE {
      VALUES (?val) { (5) (4) (3) (2) (1) }
      VALUES (?other) { (5) (4) (3) (2) (1) }
      FILTER(?other < ?val)
      OPTIONAL { BIND(?other AS ?smaller) }
    }
    GROUP BY ?val
    ORDER BY ?pos
  }
  BIND(?val AS ?sorted)
}
ORDER BY ?pos
