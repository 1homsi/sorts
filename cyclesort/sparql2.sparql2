PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX ex: <http://example.org/>

SELECT ?value ?rank
WHERE {
  VALUES (?value) { (5) (4) (3) (2) (1) }
  {
    SELECT ?value (COUNT(?smaller) AS ?rank)
    WHERE {
      VALUES (?value) { (5) (4) (3) (2) (1) }
      VALUES (?candidate) { (5) (4) (3) (2) (1) }
      FILTER (?candidate < ?value)
      BIND(?candidate AS ?smaller)
    }
    GROUP BY ?value
  }
}
ORDER BY ?rank
