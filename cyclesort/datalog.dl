.decl input(idx: number, val: number)
.decl smaller(val: number, cnt: number)
.decl sorted(pos: number, val: number)

input(0, 5). input(1, 4). input(2, 3). input(3, 2). input(4, 1).

smaller(v, count : { input(_, u), u < v }) :- input(_, v).

sorted(c, v) :- input(_, v), smaller(v, c).

.output sorted
