(define is-sorted
  [] -> true
  [_] -> true
  [A B | Rest] -> (and (<= A B) (is-sorted [B | Rest])))

(define do-bogosort
  Lst -> (if (is-sorted Lst)
             Lst
             (do-bogosort (shen-bogosort-shuffle Lst))))

(define shen-bogosort-shuffle
  Lst -> (map (fn snd)
              (sort (fn (P1 P2) (< (fst P1) (fst P2)))
                    (map (fn X -> (cons (random 1000) X)) Lst))))

(print (do-bogosort [3 1 4 1 5 9 2 6]))
