DIM arr(1 TO 8) AS INTEGER
arr(1) = 3: arr(2) = 1: arr(3) = 4: arr(4) = 1
arr(5) = 5: arr(6) = 9: arr(7) = 2: arr(8) = 6
n = 8

RANDOMIZE TIMER

DO
  sorted = 1
  FOR i = 1 TO n - 1
    IF arr(i) > arr(i + 1) THEN sorted = 0
  NEXT i

  IF sorted = 0 THEN
    FOR i = n TO 2 STEP -1
      j = INT(RND * i) + 1
      tmp = arr(i): arr(i) = arr(j): arr(j) = tmp
    NEXT i
  END IF
LOOP UNTIL sorted = 1

FOR i = 1 TO n
  PRINT arr(i);
NEXT i
PRINT
