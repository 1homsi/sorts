C BOGOSORT
U ARRAY(3),I,J,SORTED
ACCEPT ARRAY(1),ARRAY(2),ARRAY(3)
T ARRAY(1)=3,ARRAY(2)=1,ARRAY(3)=2
T SORTED=1
L LOOP
T I=1
L CH
C TEST
T I=I+1
J I+1
C(J=4) GO SHUF
C(ARRAY(I)>ARRAY(J)) T SORTED=0
GO CH
L SHUF
C(SORTED=0) T I=1
L SH
T J=1+(3*RANDOM)
T TEMP=ARRAY(I)
T ARRAY(I)=ARRAY(J)
T ARRAY(J)=TEMP
T I=I+1
C(I>3) GO LOOP
GO LOOP
C(SORTED=1) T I=1
L PRT
PRINT ARRAY(I)
T I=I+1
C(I<4) GO PRT
STOP
