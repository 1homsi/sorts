when I receive [start v]
set [arr v] to (list (3) (1) (4) (1) (5) (9) (2) (6))
set [n v] to [8]
repeat until (is sorted?)
  shuffle
end
say (arr)

define is sorted?
set [sorted v] to [true]
set [i v] to [1]
repeat ((n) - (1))
  if (item (i) of (arr)) > (item ((i) + (1)) of (arr)) then
    set [sorted v] to [false]
  end
  change [i v] by (1)
end
report (sorted)

define shuffle
set [i v] to (n)
repeat ((n) - (1))
  set [j v] to (pick random (1) to (i))
  set [tmp v] to (item (i) of (arr))
  replace item (i) of (arr) with (item (j) of (arr))
  replace item (j) of (arr) with (tmp)
  change [i v] by (-1)
end
