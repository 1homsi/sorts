is_sorted([], true).
is_sorted([_], true).
is_sorted([A,B|Rest], Result) :-
    (A =< B ->
        is_sorted([B|Rest], Result)
    ;
        Result = false
    ).

shuffle(List, Shuffled) :-
    msort(List, Shuffled).

bogosort(List, Sorted) :-
    is_sorted(List, IsSorted),
    (IsSorted = true ->
        Sorted = List
    ;
        shuffle(List, Shuffled),
        bogosort(Shuffled, Sorted)
    ).

:- bogosort([3,1,4,1,5,9,2,6], Sorted), write(Sorted), nl.
