fun bogosort(arr) {
  while (!issorted(arr)) {
    shuffle(arr);
  }
  return arr;
}

fun issorted(arr) {
  for (var i = 0; i < arr.size() - 1; i = i + 1) {
    if (arr[i] > arr[i + 1]) {
      return false;
    }
  }
  return true;
}

fun shuffle(arr) {
  for (var i = 0; i < arr.size(); i = i + 1) {
    var j = i;
    var tmp = arr[i];
    arr[i] = arr[j];
    arr[j] = tmp;
  }
}

var arr = [3, 1, 2];
print bogosort(arr);
