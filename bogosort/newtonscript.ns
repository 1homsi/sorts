func BogSort(arr) {
  local sorted;
  loop do
    sorted := true;
    local i := 0;
    loop
      if i >= length(arr) - 1 then break;
      if arr[i] > arr[i+1] then sorted := false;
      i := i + 1;
    end;
    if not sorted then
      local j := random(length(arr));
      local tmp := arr[i];
      arr[i] := arr[j];
      arr[j] := tmp;
    end;
  until sorted;
  return arr;
}

local arr := [3, 1, 2];
print(BogSort(arr));
