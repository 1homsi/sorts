dec is_sorted : list(num) -> truval;
--- is_sorted nil <= true;
--- is_sorted (x :: nil) <= true;
--- is_sorted (x :: y :: rest) <= x <= y and is_sorted (y :: rest);

dec bogosort : list(num) -> list(num);
--- bogosort lst <=
    if is_sorted lst then lst
    else bogosort (shuffle lst);

dec shuffle : list(num) -> list(num);
--- shuffle lst <= lst;

!! bogosort [3, 1, 4, 1, 5, 9, 2, 6];
