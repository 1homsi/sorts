fun is_sorted(_ arr: [Int]) -> Bool {
  var i = 0
  while i < arr.count() - 1 {
    if arr[i] > arr[i + 1] { return false }
    &i += 1
  }
  return true
}

fun shuffle(_ arr: inout [Int]) {
  var i = arr.count() - 1
  while i > 0 {
    let j = Int.random(in: 0 ..< i + 1)
    arr.swap_at(i, j)
    &i -= 1
  }
}

fun bogosort(_ arr: inout [Int]) {
  while !is_sorted(arr) {
    shuffle(&arr)
  }
}

public fun main() {
  var arr = [3, 1, 4, 1, 5, 9, 2, 6]
  bogosort(&arr)
  print(arr)
}
