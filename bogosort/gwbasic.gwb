10 DIM A(8)
20 A(1)=3:A(2)=1:A(3)=4:A(4)=1
30 A(5)=5:A(6)=9:A(7)=2:A(8)=6
40 N=8
50 RANDOMIZE
60 S=1
70 FOR I=1 TO N-1
80   IF A(I)>A(I+1) THEN S=0
90 NEXT I
100 IF S=1 THEN GOTO 160
110 FOR I=N TO 2 STEP -1
120   J=INT(RND*I)+1
130   T=A(I):A(I)=A(J):A(J)=T
140 NEXT I
150 GOTO 60
160 FOR I=1 TO N
170   PRINT A(I);" ";
180 NEXT I
190 PRINT
200 END
