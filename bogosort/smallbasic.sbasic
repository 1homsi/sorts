arr[1] = 3
arr[2] = 1
arr[3] = 4
arr[4] = 1
arr[5] = 5
arr[6] = 9
arr[7] = 2
arr[8] = 6
n = 8

sorted = 0
While sorted = 0
  sorted = 1
  For i = 1 To n - 1
    If arr[i] > arr[i + 1] Then sorted = 0
  EndFor
  If sorted = 0 Then
    For i = n To 2 Step -1
      j = Math.Floor(Math.GetRandomNumber(i)) + 1
      tmp = arr[i]
      arr[i] = arr[j]
      arr[j] = tmp
    EndFor
  EndIf
EndWhile

For i = 1 To n
  TextWindow.Write(arr[i] + " ")
EndFor
TextWindow.WriteLine("")
