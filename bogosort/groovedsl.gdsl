def isSorted = { arr ->
    for (int i = 0; i < arr.size() - 1; i++) {
        if (arr[i] > arr[i + 1]) return false
    }
    return true
}

def bogosort = { arr ->
    def a = arr as List
    while (!isSorted(a)) Collections.shuffle(a)
    a
}

def arr = [3, 1, 4, 1, 5, 9, 2, 6]
println bogosort(arr)
