fun isSorted(arr) {
    var n = length(arr);
    var sorted = true;
    var i = 0;
    while (i < n - 1) {
        if (nth(arr, i) > nth(arr, i + 1)) sorted := false;
        i := i + 1
    };
    sorted
}

fun shuffle(arr) {
    sortBy(fun(_, _) { randomFloat() > 0.5 }, arr)
}

fun bogosort(arr) {
    if (isSorted(arr)) arr
    else bogosort(shuffle(arr))
}

var arr = [3, 1, 4, 1, 5, 9, 2, 6];
println(show(bogosort(arr)))
