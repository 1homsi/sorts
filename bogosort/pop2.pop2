vars arr sorted i j n tmp;
[3 1 2] -> arr;
length(arr) -> n;
0 -> sorted;

until sorted do
  1 -> sorted;
  for i from 0 to n - 2 do
    if arr(i) > arr(i + 1) then
      0 -> sorted;
    endif;
  endfor;

  if not(sorted) then
    for i from 0 to n - 1 do
      random(n) -> j;
      arr(i) -> tmp;
      arr(j) -> arr(i);
      tmp -> arr(j);
    endfor;
  endif;
enduntil;

arr =>
