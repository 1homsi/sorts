import Val.Standard

fun is_sorted(arr: Array<Int>) -> Bool {
  for i in 0 ..< arr.count - 1 {
    if arr[i] > arr[i + 1] { return false }
  }
  return true
}

fun shuffle(arr: inout Array<Int>) {
  let n = arr.count
  for i in (1 ..< n).reversed() {
    let j = Int.random(in: 0 ... i)
    arr.swapAt(i, j)
  }
}

fun bogosort(arr: inout Array<Int>) {
  while !is_sorted(arr) {
    shuffle(&arr)
  }
}

var arr = [3, 1, 4, 1, 5, 9, 2, 6]
bogosort(&arr)
print(arr)
