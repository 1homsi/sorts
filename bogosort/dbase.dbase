PRIVATE arr[8], n, sorted, i, j, tmp

arr[1]=3 & arr[2]=1 & arr[3]=4 & arr[4]=1
arr[5]=5 & arr[6]=9 & arr[7]=2 & arr[8]=6
n=8

DO WHILE .T.
  sorted=.T.
  i=1
  DO WHILE i<=n-1
    IF arr[i]>arr[i+1]
      sorted=.F.
    ENDIF
    i=i+1
  ENDDO
  IF sorted
    EXIT
  ENDIF
  i=n
  DO WHILE i>=2
    j=INT(RAND()*i)+1
    tmp=arr[i] & arr[i]=arr[j] & arr[j]=tmp
    i=i-1
  ENDDO
ENDDO

i=1
DO WHILE i<=n
  ? arr[i]
  i=i+1
ENDDO
