DIM arr(8)
arr(1)=3:arr(2)=1:arr(3)=4:arr(4)=1
arr(5)=5:arr(6)=9:arr(7)=2:arr(8)=6
n=8

REPEAT
  sorted=TRUE
  FOR i=1 TO n-1
    IF arr(i)>arr(i+1) THEN sorted=FALSE
  NEXT i
  IF NOT sorted THEN
    FOR i=n TO 2 STEP -1
      j=RND(i)
      tmp=arr(i):arr(i)=arr(j):arr(j)=tmp
    NEXT i
  ENDIF
UNTIL sorted

FOR i=1 TO n
  PRINT arr(i);" ";
NEXT i
PRINT
