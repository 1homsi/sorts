isSorted : [Nat] -> Boolean
isSorted arr =
  size = List.size arr
  check i =
    if i >= size - 1 then true
    else
      a = List.at arr i
      b = List.at arr (i + 1)
      match (a, b) with
        (Some x, Some y) -> x <= y && check (i + 1)
        _ -> true
  check 0

bogosort : [Nat] -> [Nat]
bogosort arr =
  if isSorted arr then arr
  else bogosort (List.shuffle arr)

arr = [3, 1, 4, 1, 5, 9, 2, 6]
> bogosort arr
