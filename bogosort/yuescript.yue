is_sorted = (arr) ->
  for i = 1, #arr - 1
    return false if arr[i] > arr[i + 1]
  true

shuffle = (arr) ->
  n = #arr
  for i = n, 2, -1
    j = math.random i
    arr[i], arr[j] = arr[j], arr[i]

bogosort = (arr) ->
  arr = [x for x in *arr]
  until is_sorted arr
    shuffle arr
  arr

math.randomseed os.time!
arr = {3, 1, 4, 1, 5, 9, 2, 6}
print table.concat(bogosort(arr), " ")
