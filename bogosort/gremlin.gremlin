g = TinkerGraph.open().traversal()

def isSorted(arr) {
    for (int i = 0; i < arr.size() - 1; i++) {
        if (arr[i] > arr[i+1]) return false
    }
    return true
}

def shuffle(arr) {
    Collections.shuffle(arr)
    arr
}

def bogosort(arr) {
    while (!isSorted(arr)) arr = shuffle(arr)
    arr
}

println bogosort([3, 1, 4, 1, 5, 9, 2, 6])
