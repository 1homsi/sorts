MAIN
BEGIN
  INT ARRAY A(3);
  INT I, J, SORTED;

  A(1) := 3;
  A(2) := 1;
  A(3) := 2;

  DO
    SORTED := TRUE;
    FROM I := 1 TO 2 DO
      IF A(I) > A(I+1) THEN
        SORTED := FALSE;
      FI;
    OD;

    IF NOT SORTED THEN
      FROM I := 1 TO 3 DO
        J := RANDOM(3) + 1;
        SWAP(A(I), A(J));
      OD;
    FI;
  UNTIL SORTED;

  PRINT A;
END;
