section bogosort

IsSorted = H arr n =>
{ sorted = true
  for i = 1 step 1 until n-1 do
    if arr(i) > arr(i+1) then sorted := false
  value sorted
}

Shuffle = H arr n =>
{ for i = n step -1 until 2 do
    { j = rand() rem i + 1
      tmp = arr(i)
      arr(i) := arr(j)
      arr(j) := tmp
    }
}

Bogosort = H arr n =>
{ until IsSorted(arr, n) do Shuffle(arr, n)
}

let arr = Array [3; 1; 4; 1; 5; 9; 2; 6]
let n = 8
Bogosort(arr, n)
for i = 1 step 1 until n do Print(arr(i))
end section
