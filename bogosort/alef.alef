void bogosort(int *arr, int n) {
  while (!issorted(arr, n)) {
    shuffle(arr, n);
  }
}

int issorted(int *arr, int n) {
  for (int i = 0; i < n - 1; i++) {
    if (arr[i] > arr[i+1]) {
      return 0;
    }
  }
  return 1;
}

void shuffle(int *arr, int n) {
  for (int i = 0; i < n; i++) {
    int j = rand() % n;
    int tmp = arr[i];
    arr[i] = arr[j];
    arr[j] = tmp;
  }
}

void main() {
  int arr[] = {3, 1, 2};
  bogosort(arr, 3);
}
