def isSorted(arr: List[Int]): Bool =
  match arr with
  | [] -> true
  | [_] -> true
  | x::y::rest -> x <= y && isSorted(y::rest)

def shuffle(arr: List[Int]): List[Int] =
  let n = length(arr)
  let v = vec(arr)
  for i = n-1 downto 1 do
    let j = random() mod (i+1)
    let tmp = v[i]
    v[i] = v[j]
    v[j] = tmp
  list(v)

def rec bogosort(arr: List[Int]): List[Int] =
  if isSorted(arr) then arr
  else bogosort(shuffle(arr))

let arr = [3; 1; 4; 1; 5; 9; 2; 6]
print(bogosort(arr))
