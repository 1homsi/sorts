package bogosort

uses java.util.ArrayList
uses java.util.Collections

function isSorted(arr: List<Integer>): boolean {
    for (i in 0..|arr.size() - 1|) {
        if (arr.get(i) > arr.get(i + 1)) return false
    }
    return true
}

function bogosort(arr: List<Integer>): List<Integer> {
    var list = new ArrayList<Integer>(arr)
    while (!isSorted(list)) {
        Collections.shuffle(list)
    }
    return list
}

var arr: List<Integer> = {3, 1, 4, 1, 5, 9, 2, 6}
print(bogosort(arr))
