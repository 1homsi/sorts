-module(erlang2).
-export([main/0]).

is_sorted([]) -> true;
is_sorted([_]) -> true;
is_sorted([A, B | Rest]) when A =< B -> is_sorted([B | Rest]);
is_sorted(_) -> false.

shuffle(List) ->
    [X || {_, X} <- lists:sort([{rand:uniform(), E} || E <- List])].

bogosort(List) ->
    case is_sorted(List) of
        true -> List;
        false -> bogosort(shuffle(List))
    end.

main() ->
    Arr = [3, 1, 4, 1, 5, 9, 2, 6],
    io:format("~p~n", [bogosort(Arr)]).
