PROGRAM BOGOSORT;
  DECLARE A(3) FIXED;
  DECLARE I, J, N, T FIXED;
  DECLARE SORTED BIT;

  A(1) = 3;
  A(2) = 1;
  A(3) = 2;
  N = 3;

LOOP:
  SORTED = TRUE;
  DO I = 1 TO N-1;
    IF A(I) > A(I+1) THEN SORTED = FALSE;
  END;

  IF NOT SORTED THEN DO;
    DO I = 1 TO N;
      J = MOD(RANDOM, N) + 1;
      T = A(I);
      A(I) = A(J);
      A(J) = T;
    END;
    GO TO LOOP;
  END;

  PRINT A(1), A(2), A(3);
  STOP;
END;
