DIMENSION arr(8)
arr(1)=3 & arr(2)=1 & arr(3)=4 & arr(4)=1
arr(5)=5 & arr(6)=9 & arr(7)=2 & arr(8)=6
n=8

DO WHILE .T.
  sorted=.T.
  FOR i=1 TO n-1
    IF arr(i)>arr(i+1)
      sorted=.F.
    ENDIF
  ENDFOR
  IF sorted
    EXIT
  ENDIF
  FOR i=n TO 2 STEP -1
    j=INT(RAND()*i)+1
    tmp=arr(i) & arr(i)=arr(j) & arr(j)=tmp
  ENDFOR
ENDDO

FOR i=1 TO n
  ? arr(i)
ENDFOR
