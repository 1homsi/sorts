use std

const bogosort = {arr : int[:] -> int[:]
  while !issorted(arr)
    shuffle(arr)
  ;;
  -> arr
}

const issorted = {arr : int[:]
  for var i = 0; i < arr.len - 1; i++
    if arr[i] > arr[i+1]
      -> false
    ;;
  ;;
  -> true
}

const shuffle = {arr : int[:]
  for var i = 0; i < arr.len; i++
    var j = (std.rand() % arr.len) castto(int)
    var tmp = arr[i]
    arr[i] = arr[j]
    arr[j] = tmp
  ;;
}

const main = {
  var arr = [3, 1, 2]
  std.print(bogosort(arr))
}
