import util.

is_sorted([]) => true.
is_sorted([_]) => true.
is_sorted([A, B | Rest]) =>
    A =< B,
    is_sorted([B | Rest]).

shuffle(List) = Shuffled =>
    Shuffled = [X : _ = _X, X in List].

bogosort(List) = Sorted =>
    if is_sorted(List) then
        Sorted = List
    else
        Shuffled = shuffle(List),
        Sorted = bogosort(Shuffled)
    end.

main =>
    Arr = [3, 1, 4, 1, 5, 9, 2, 6],
    Sorted = bogosort(Arr),
    println(Sorted).
