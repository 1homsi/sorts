fn is_sorted(arr: str) -> bool
    let arr = split $arr ","
    let n = len $arr
    let i = 0
    while [ $i -lt $(( $n - 1 )) ]
        let j = $(( $i + 1 ))
        if [ $(arr[$i]) -gt $(arr[$j]) ]
            return false
        end
        let i = $(( $i + 1 ))
    end
    return true
end

let arr = "3,1,4,1,5,9,2,6"
