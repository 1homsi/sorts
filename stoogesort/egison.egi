(define stoogesort
  (lambda (a i j)
    (if (< (vector-ref a j) (vector-ref a i))
      (let ((temp (vector-ref a j)))
        (vector-set! a j (vector-ref a i))
        (vector-set! a i temp)))
    (if (> (- j i) 1)
      (let ((t (quotient (+ (- j i) 1) 3)))
        (stoogesort a i (- j t))
        (stoogesort a (+ i t) j)
        (stoogesort a i (- j t))))))

(define arr (vector 5 2 8 1 9 3))
(stoogesort arr 0 5)
(print arr)
