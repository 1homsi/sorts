def stoogesort(a: uint[], i: uint, j: uint) {
  if (a[j] < a[i]) {
    let tmp = a[j];
    a[j] := a[i];
    a[i] := tmp;
  }
  if (j - i > 1) {
    let t = (j - i + 1) / 3;
    stoogesort(a, i, j - t);
    stoogesort(a, i + t, j);
    stoogesort(a, i, j - t);
  }
  return a;
}

def main() {
  let arr = [5, 2, 8, 1, 9, 3];
  stoogesort(arr, 0, 5);
  return arr;
}
