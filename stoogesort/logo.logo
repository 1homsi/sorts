to stoogesort :a :i :j
  if (item :j :a) < (item :i :a) [
    let "temp item :j :a
    setitem :j :a item :i :a
    setitem :i :a :temp
  ]
  if :j - :i > 1 [
    let "t (:j - :i + 1) / 3
    stoogesort :a :i :j - :t
    stoogesort :a :i + :t :j
    stoogesort :a :i :j - :t
  ]
end

stoogesort [5 2 8 1 9 3] 1 6
print ""
