procedure Stoogesort(var A : Array<Integer>; I, J : Integer) is
  T : Integer;
begin
  if A[J] < A[I] then
    declare Temp := A[J];
    A[J] := A[I];
    A[I] := Temp;
  end if;
  
  if J - I > 1 then
    T := (J - I + 1) / 3;
    Stoogesort(A, I, J - T);
    Stoogesort(A, I + T, J);
    Stoogesort(A, I, J - T);
  end if;
end procedure Stoogesort;
