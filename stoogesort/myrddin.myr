pkg stoogesort =
  const stoogesort : (a : int[:], i : int, j : int -> void)

impl stoogesort =
  const stoogesort = {a, i, j
    if a[j] < a[i]
      var t = a[j]
      a[j] = a[i]
      a[i] = t
    ;;
    if j - i > 1
      var t = (j - i + 1) / 3
      stoogesort(a, i, j - t)
      stoogesort(a, i + t, j)
      stoogesort(a, i, j - t)
    ;;
  }

  const main = {
    var arr = [5, 2, 8, 1, 9, 3][:]
    stoogesort(arr, 0, 5)
  }
