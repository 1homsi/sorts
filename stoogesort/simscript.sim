routine stoogesort(a, i, j)
  if a(j) < a(i) then
    let temp = a(j)
    let a(j) = a(i)
    let a(i) = temp
  end if
  if j - i > 1 then
    let t = (j - i + 1) / 3
    call stoogesort(a, i, j - t)
    call stoogesort(a, i + t, j)
    call stoogesort(a, i, j - t)
  end if
end

create entity
activate entity now
process until all entities finished

set a(1)=5, a(2)=2, a(3)=8, a(4)=1, a(5)=9, a(6)=3
call stoogesort(a, 1, 6)
print a(1), a(2), a(3), a(4), a(5), a(6)
end
