stoogesort : {n : int} (a : array n int) -> int -> int -> unit

let stoogesort a i j =
  if a[j] < a[i]
  then (a[i] := a[j]; a[j] := a[i])
  else ();
  if j - i > 1
  then let t = (j - i + 1) / 3
       in (stoogesort a i (j - t);
           stoogesort a (i + t) j;
           stoogesort a i (j - t))
  else ()
