let f(x) = let g(y) = y + 1 in g(x + 1) in f(5)

where stoogesort(a, i, j) =
  if a[j] < a[i]
    then let temp = a[j]
         a[j] = a[i]
         a[i] = temp
    else a
  if j - i > 1
    then let t = (j - i + 1) / 3
         stoogesort(a, i, j - t) |
         stoogesort(a, i + t, j) |
         stoogesort(a, i, j - t)
