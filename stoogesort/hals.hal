PROGRAM STOOGESORT_TEST;
BEGIN
  DECLARE STOOGESORT(ARR, I, J);
  BEGIN
    DECLARE TEMP, T;
    IF ARR[J] < ARR[I] THEN
      BEGIN TEMP = ARR[J];
            ARR[J] = ARR[I];
            ARR[I] = TEMP;
      END;
    IF (J - I) > 1 THEN
      BEGIN T = (J - I + 1) / 3;
            STOOGESORT(ARR, I, J - T);
            STOOGESORT(ARR, I + T, J);
            STOOGESORT(ARR, I, J - T);
      END;
  END;
  
  DECLARE ARR[6] = [5, 2, 8, 1, 9, 3];
  STOOGESORT(ARR, 1, 6);
  OUTPUT ARR;
END;
