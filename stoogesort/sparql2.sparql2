PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?val WHERE {
    VALUES (?val) { ("3"^^xsd:integer) ("1"^^xsd:integer) ("4"^^xsd:integer) ("1"^^xsd:integer)
                    ("5"^^xsd:integer) ("9"^^xsd:integer) ("2"^^xsd:integer) ("6"^^xsd:integer) }
}
ORDER BY ?val
