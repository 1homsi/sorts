proc stoogesort(a: &array[int], i: int, j: int) {
  if a.j < a.i {
    let temp = a.j;
    a.j <- a.i;
    a.i <- temp;
  }
  if j - i > 1 {
    let t = (j - i + 1) / 3;
    stoogesort(a, i, j - t);
    stoogesort(a, i + t, j);
    stoogesort(a, i, j - t);
  }
}

var arr = array(5, 2, 8, 1, 9, 3);
stoogesort(&arr, 0, 5);
println arr;
