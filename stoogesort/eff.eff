let stoogesort a i j =
  if a.(j) < a.(i) then
    let temp = a.(j) in
    (a.(j) <- a.(i); a.(i) <- temp);
  if j - i > 1 then
    let t = (j - i + 1) / 3 in
    (stoogesort a i (j - t);
     stoogesort a (i + t) j;
     stoogesort a i (j - t))

let () =
  let arr = [|5; 2; 8; 1; 9; 3|] in
  stoogesort arr 0 5;
  Array.iter (Printf.printf "%d ") arr
