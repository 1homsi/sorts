function stoogesort(a, i, j) {
  if (a[j] < a[i]) {
    var temp = a[j];
    a[j] = a[i];
    a[i] = temp;
  }
  if (j - i > 1) {
    var t = Math.floor((j - i + 1) / 3);
    stoogesort(a, i, j - t);
    stoogesort(a, i + t, j);
    stoogesort(a, i, j - t);
  }
}

var arr = [5, 2, 8, 1, 9, 3];
stoogesort(arr, 0, 5);
WScript.Echo(arr);
