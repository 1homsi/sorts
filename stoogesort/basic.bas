10 DIM ARR(8)
20 ARR(1)=3:ARR(2)=1:ARR(3)=4:ARR(4)=1:ARR(5)=5:ARR(6)=9:ARR(7)=2:ARR(8)=6
30 GOSUB 100
40 FOR I=1 TO 8:PRINT ARR(I);" ":NEXT I
50 PRINT
60 END
100 FIRST=1:LAST=8
110 GOSUB 200
120 RETURN
200 IF ARR(FIRST)>ARR(LAST) THEN T=ARR(FIRST):ARR(FIRST)=ARR(LAST):ARR(LAST)=T
210 N=LAST-FIRST+1
220 IF N<=2 THEN RETURN
230 T=INT(N*2/3)
240 SAVEFIRST=FIRST:SAVELAST=LAST
250 LAST=FIRST+T-1:GOSUB 200:FIRST=SAVEFIRST:LAST=SAVELAST
260 FIRST=LAST-T+1:GOSUB 200:FIRST=SAVEFIRST:LAST=SAVELAST
270 LAST=FIRST+T-1:GOSUB 200:FIRST=SAVEFIRST:LAST=SAVELAST
280 RETURN
