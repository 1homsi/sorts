stoogesort :: MRef s (Array s Int) -> Int -> Int -> ST s ()
stoogesort a i j = do
  av <- read a
  if av!j < av!i then do
    let temp = av!j
    write a (av // [(j, av!i), (i, temp)])
  else
    return ()
  if j - i > 1 then do
    let t = (j - i + 1) `div` 3
    stoogesort a i (j - t)
    stoogesort a (i + t) j
    stoogesort a i (j - t)
  else
    return ()

main = runST $ do
  a <- new (array [5,2,8,1,9,3])
  stoogesort a 0 5
