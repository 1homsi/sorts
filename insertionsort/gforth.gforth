: insertion-sort ( addr n -- )
  1 DO
    I CELLS OVER + @
    I 1-
    BEGIN
      DUP 0 >=
    WHILE
      2DUP CELLS 2 PICK + @ ROT ROT > IF
        DUP CELLS 2 PICK + @
        OVER 1+ CELLS 2 PICK + !
        1-
      ELSE
        DROP LEAVE
      THEN
    REPEAT
    1+ CELLS OVER + !
  LOOP
  DROP ;
