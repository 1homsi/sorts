insertion_sort() {
    local -n arr=$1
    for ((i = 1; i < ${#arr[@]}; i++)); do
        local key=${arr[$i]}
        local j=$((i - 1))
        while [ $j -ge 0 ] && [ ${arr[$j]} -gt $key ]; do
            arr[$((j + 1))]=${arr[$j]}
            ((j--))
        done
        arr[$((j + 1))]=$key
    done
}
