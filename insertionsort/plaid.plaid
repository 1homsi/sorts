method insertionSort(arr: Array[Int], n: Int): Array[Int] {
    var i: Int = 1;
    while (i < n) {
        val key: Int = arr.get(i);
        var j: Int = i - 1;
        while (j >= 0 && arr.get(j) > key) {
            arr.set(j + 1, arr.get(j));
            j = j - 1;
        }
        arr.set(j + 1, key);
        i = i + 1;
    }
    arr
}
