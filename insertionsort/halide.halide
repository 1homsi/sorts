#include "Halide.h"
using namespace Halide;

Func insertion_sort_halide(Buffer<int32_t> input) {
    Var x;
    Func sorted;
    int n = input.width();
    std::vector<int32_t> a(input.begin(), input.end());
    for (int i = 1; i < n; i++) {
        int key = a[i];
        int j = i - 1;
        while (j >= 0 && a[j] > key) {
            a[j + 1] = a[j];
            j--;
        }
        a[j + 1] = key;
    }
    sorted(x) = cast<int32_t>(a[x]);
    return sorted;
}
