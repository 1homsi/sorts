@start
[[Sort]]

[Sort]
{@insertion_sort([5,3,1,4,2])}

@js
function insertion_sort(arr) {
    var a = arr.slice();
    var n = a.length;
    for (var i = 1; i < n; i++) {
        var key = a[i];
        var j = i - 1;
        while (j >= 0 && a[j] > key) {
            a[j + 1] = a[j];
            j--;
        }
        a[j + 1] = key;
    }
    return a.join(', ');
}
