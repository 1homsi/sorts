routine InsertionSort(arr, n)
{
    local i, j, key
    for (i=1; i<n; i++)
    {
        key = array arr[i]
        j = i - 1
        while (j >= 0 and array arr[j] > key)
        {
            array arr[j+1] = array arr[j]
            j--
        }
        array arr[j+1] = key
    }
}

routine init
{
    local data[5]
    data[0] = 5  data[1] = 3  data[2] = 1  data[3] = 4  data[4] = 2
    InsertionSort(data, 5)
    print data[0]; ", "; data[1]; ", "; data[2]; ", "; data[3]; ", "; data[4]
}
