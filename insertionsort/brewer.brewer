tap "homebrew/core"

formula "insertion-sort" do
  desc "Insertion sort algorithm demonstration"
  homepage "https://example.com"
  url "https://example.com/insertion-sort-1.0.tar.gz"
  version "1.0"

  def install
    system "python3", "-c", "
arr = [5, 3, 1, 4, 2]
for i in range(1, len(arr)):
    key = arr[i]; j = i - 1
    while j >= 0 and arr[j] > key:
        arr[j+1] = arr[j]; j -= 1
    arr[j+1] = key
print(arr)
"
  end
end
