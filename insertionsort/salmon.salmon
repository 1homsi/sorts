define insertionSort(array) as {
  variable n = length(array);
  for i from 2 to n {
    variable key = array[i];
    variable j = i - 1;
    while j >= 1 and array[j] > key {
      array[j + 1] = array[j];
      j = j - 1;
    }
    array[j + 1] = key;
  }
  return array;
}

print insertionSort([5, 2, 8, 1, 9, 3]);