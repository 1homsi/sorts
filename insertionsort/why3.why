module InsertionSort

  use int.Int
  use array.Array

  let insertion_sort (arr: array int) : unit
    ensures { forall i j. 0 <= i < j < length arr -> arr[i] <= arr[j] }
  =
    let n = length arr in
    for i = 1 to n - 1 do
      let key = arr[i] in
      let j = ref (i - 1) in
      while !j >= 0 && arr[!j] > key do
        arr[!j + 1] <- arr[!j];
        decr j
      done;
      arr[!j + 1] <- key
    done

end
