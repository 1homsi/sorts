include "sciter:reactor.tis";

function insertionSort(arr) {
  var a = arr.clone();
  var n = a.length;
  for (var i = 1; i < n; i++) {
    var key = a[i];
    var j = i - 1;
    while (j >= 0 && a[j] > key) {
      a[j + 1] = a[j];
      j--;
    }
    a[j + 1] = key;
  }
  return a;
}

var result = insertionSort([5, 3, 1, 4, 2]);
$(#output).text = result.join(", ");
