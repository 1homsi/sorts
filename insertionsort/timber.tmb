main(world:RealWorld) :> RealWorld {
  let arr = [5, 2, 8, 1, 9, 3] :: [Int]
  let sorted = insertionSort(arr)
  do putStrLn (show sorted)
  return world
}

insertionSort :: [a] -> [a]
insertionSort [] = []
insertionSort [x] = [x]
insertionSort (x:xs) = insert x (insertionSort xs)

insert :: Ord a => a -> [a] -> [a]
insert x [] = [x]
insert x (y:ys) = if x <= y then x:y:ys else y:(insert x ys)