run() = {
  insertionSort(arr: Array[ZZ32, ZZ32]) = {
    n = |arr|
    for i <- 1:n do
      key = arr[i]
      j = i - 1
      while j >= 0 and arr[j] > key do
        arr[j+1] := arr[j]
        j := j - 1
      end
      arr[j+1] := key
    end
    arr
  }
  println(insertionSort(array[5, 2, 8, 1, 9, 3]))
}