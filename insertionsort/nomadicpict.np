letrec insertSorted =
    fun (x: int, lst: list[int]) ->
        match lst with
        | [] -> [x]
        | y :: ys ->
            if x <= y then x :: y :: ys
            else y :: insertSorted(x, ys)

letrec insertionSort =
    fun (lst: list[int]) ->
        match lst with
        | [] -> []
        | x :: xs -> insertSorted(x, insertionSort(xs))

in insertionSort
