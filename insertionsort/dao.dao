routine InsertionSort(arr: list<int>): list<int> {
  var n = arr.size();
  for (var i = 1; i < n; i += 1) {
    var key = arr[i];
    var j = i - 1;
    while (j >= 0 && arr[j] > key) {
      arr[j+1] = arr[j];
      j -= 1;
    }
    arr[j+1] = key;
  }
  return arr;
}

var arr = [5, 2, 8, 1, 9, 3];
println(InsertionSort(arr));