:- module(sort, [main/0]).

main :- insertion_sort([5,2,8,1,9,3], R), write(R), nl.

insertion_sort([], []).
insertion_sort([H|T], Sorted) :- insertion_sort(T, SortedT), insert(H, SortedT, Sorted).

insert(X, [], [X]).
insert(X, [H|T], [X,H|T]) :- X =< H, !.
insert(X, [H|T], [H|R]) :- insert(X, T, R).