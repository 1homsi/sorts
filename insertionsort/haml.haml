- def insertion_sort(arr)
-   a = arr.dup
-   n = a.length
-   (1...n).each do |i|
-     key = a[i]
-     j = i - 1
-     while j >= 0 && a[j] > key
-       a[j + 1] = a[j]
-       j -= 1
-     end
-     a[j + 1] = key
-   end
-   a
- end
- result = insertion_sort([5, 3, 1, 4, 2])
%p= result.join(', ')
