(letrec ((insert (lambda (x lst)
                  (if (null? lst)
                      (cons x nil)
                      (if (<= x (car lst))
                          (cons x lst)
                          (cons (car lst) (insert x (cdr lst)))))))
         (insertion-sort (lambda (lst)
                           (if (null? lst)
                               nil
                               (insert (car lst) (insertion-sort (cdr lst)))))))
  (insertion-sort '(5 3 1 4 2)))
