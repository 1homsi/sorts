{php}
function insertion_sort($arr) {
    $n = count($arr);
    for ($i = 1; $i < $n; $i++) {
        $key = $arr[$i];
        $j = $i - 1;
        while ($j >= 0 && $arr[$j] > $key) {
            $arr[$j + 1] = $arr[$j];
            $j--;
        }
        $arr[$j + 1] = $key;
    }
    return $arr;
}
$result = insertion_sort([5, 3, 1, 4, 2]);
$this->assign('result', implode(', ', $result));
{/php}
{$result}
