function insertionSort(int[] arr) -> (int[] result)
ensures |result| == |arr|
ensures all { i in 0..|result|-1 | result[i] <= result[i+1] }:
    int n = |arr|
    int i = 1
    while i < n:
        int key = arr[i]
        int j = i - 1
        while j >= 0 && arr[j] > key:
            arr[j + 1] = arr[j]
            j = j - 1
        arr[j + 1] = key
        i = i + 1
    return arr
