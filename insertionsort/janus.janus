function insertionSort(inout arr: Array[Integer]) {
  variable n = arr.length;
  variable i = 1;
  variable j = 0;
  variable key = 0;
  while (i < n) {
    key = arr[i];
    j = i - 1;
    while (j >= 0 && arr[j] > key) {
      arr[j+1] = arr[j];
      j = j - 1;
    }
    arr[j+1] = key;
    i = i + 1;
  }
}

Array[Integer] arr = [5, 2, 8, 1, 9, 3];
insertionSort(arr);
print(arr);