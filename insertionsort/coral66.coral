INTEGER PROCEDURE INSERTION SORT(ARR, N);
    INTEGER ARRAY ARR; INTEGER N;
BEGIN
    INTEGER I, J, KEY;
    FOR I := 1 STEP 1 UNTIL N-1 DO
    BEGIN
        KEY := ARR(I);
        J := I - 1;
        WHILE J >= 0 AND ARR(J) > KEY DO
        BEGIN
            ARR(J+1) := ARR(J);
            J := J - 1;
        END;
        ARR(J+1) := KEY;
    END;
END;
