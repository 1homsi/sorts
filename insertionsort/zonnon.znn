module InsertionSortZNN;

procedure Sort(var arr: array of integer; n: integer);
var i, j, key: integer;
begin
    for i := 1 to n - 1 do
        key := arr[i];
        j := i - 1;
        while (j >= 0) & (arr[j] > key) do
            arr[j+1] := arr[j];
            dec(j);
        end;
        arr[j+1] := key;
    end;
end Sort;

end InsertionSortZNN.
