local function insertion_sort(arr: span(integer)): span(integer)
    local n = #arr
    for i = 1, <n do
        local key = arr[i]
        local j = i - 1
        while j >= 0 and arr[j] > key do
            arr[j + 1] = arr[j]
            j = j - 1
        end
        arr[j + 1] = key
    end
    return arr
end
