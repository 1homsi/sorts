InsertionSort:
(# sort:
   (# arr: ^Array; n: @integer
   enter (arr[], n)
   do (for i: 1 to n - 1 repeat
         (key: @integer; j: @integer;
          arr[i] -> key;
          i - 1 -> j;
          (while j >= 0 and arr[j] > key repeat
             arr[j] -> arr[j+1];
             j - 1 -> j
          );
          key -> arr[j+1])
       end for)
   #)
#)
