local function insertion_sort(arr: {integer}): {integer}
    local n = #arr
    for i = 2, n do
        local key = arr[i]
        local j = i - 1
        while j >= 1 and arr[j] > key do
            arr[j + 1] = arr[j]
            j = j - 1
        end
        arr[j + 1] = key
    end
    return arr
end
