extends Node

func insertion_sort(arr: Array) -> Array:
    var a = arr.duplicate()
    var n = a.size()
    for i in range(1, n):
        var key = a[i]
        var j = i - 1
        while j >= 0 and a[j] > key:
            a[j + 1] = a[j]
            j -= 1
        a[j + 1] = key
    return a

func _ready():
    var result = insertion_sort([5, 3, 1, 4, 2])
    print(result)
