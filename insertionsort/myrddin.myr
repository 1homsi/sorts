const insertionSort = {arr : int[:] -> int[:]
  var n = std.sllen(arr)
  for var i = 1; i < n; i++
    var key = arr[i]
    var j = i - 1
    while j >= 0 && arr[j] > key
      arr[j+1] = arr[j]
      j--
    ;;
    arr[j+1] = key
  ;;
  -> arr
};

const main = {-> std.exit(0)
  var arr = [5, 2, 8, 1, 9, 3][:]  
  std.put("{}
", insertionSort(arr))
};