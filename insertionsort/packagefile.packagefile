{
  "name": "insertion-sort",
  "version": "1.0.0",
  "description": "Insertion sort implementation",
  "main": "index.js",
  "scripts": {
    "sort": "node -e \"const s=(a)=>{for(let i=1;i<a.length;i++){let k=a[i],j=i-1;while(j>=0&&a[j]>k){a[j+1]=a[j];j--}a[j+1]=k}return a};console.log(s([5,3,1,4,2]))\""
  }
}
