rec insertionSort : list (int) -> list (int) =
  fn xs => case xs of
  | [] => []
  | (x :: xs) => insert x (insertionSort xs)

and insert : int -> list (int) -> list (int) =
  fn x => fn ys => case ys of
  | [] => [x]
  | (y :: ys) => if x <= y then (x :: y :: ys) else (y :: insert x ys)

let _ = insertionSort [5, 2, 8, 1, 9, 3]
let _ = print_list (insertionSort [5, 2, 8, 1, 9, 3])