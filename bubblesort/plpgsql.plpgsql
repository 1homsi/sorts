DO $$
DECLARE
    arr INT[] := ARRAY[64, 34, 25, 12, 22, 11, 90];
    n   INT := 7;
    tmp INT;
    swapped BOOLEAN;
BEGIN
    LOOP
        swapped := FALSE;
        FOR i IN 1..n-1 LOOP
            IF arr[i] > arr[i+1] THEN
                tmp := arr[i];
                arr[i] := arr[i+1];
                arr[i+1] := tmp;
                swapped := TRUE;
            END IF;
        END LOOP;
        n := n - 1;
        EXIT WHEN NOT swapped;
    END LOOP;
    RAISE NOTICE '%', arr;
END;
$$;
