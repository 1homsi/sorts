fun bubblesort (arr: array[int]): array[int] = {
  var a = arr;
  let n = a.len();
  for i in 0usize upto n do
    for j in 0usize upto n - 1u - i do
      if a.j > a.(j+1u) do
        let temp = a.j;
        a.(j) <- a.(j+1u);
        a.(j+1u) <- temp;
      done
    done
  done;
  return a;
};

var result = bubblesort [5, 2, 8, 1, 9, 3];
println result;