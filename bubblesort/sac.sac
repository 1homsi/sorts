use Array: all;
use StdIO: all;

int[7] bubbleSort(int[7] arr)
{
    int n = 7;
    bool swapped = true;
    int tmp;
    int[7] a = arr;

    while (swapped) {
        swapped = false;
        for (int i = 0; i < n - 1; i++) {
            if (a[i] > a[i+1]) {
                tmp = a[i];
                a[i] = a[i+1];
                a[i+1] = tmp;
                swapped = true;
            }
        }
        n = n - 1;
    }
    return a;
}

int main()
{
    int[7] arr = [64, 34, 25, 12, 22, 11, 90];
    int[7] sorted = bubbleSort(arr);
    for (int i = 0; i < 7; i++) {
        printf("%d ", sorted[i]);
    }
    printf("\n");
    return 0;
}
