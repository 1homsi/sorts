class BubbleSort
    def main
        arr = [64, 34, 25, 12, 22, 11, 90]
        .bubbleSort(arr)
        print arr

    def bubbleSort(arr as List<of int>)
        n = arr.count
        swapped = true
        while swapped
            swapped = false
            for i in n - 1
                if arr[i] > arr[i+1]
                    tmp = arr[i]
                    arr[i] = arr[i+1]
                    arr[i+1] = tmp
                    swapped = true
            n -= 1
