SPEEDCODING BUBBLE SORT
SET A 64 34 25 12 22 11 90
SET N 7
OUTER:
SET SW 0
SET I 1
INNER:
  IF I GE N GOTO DONE_INNER
  LOAD A[I]
  SUB A[I+1]
  IF LE GOTO NO_SWAP
  LOAD A[I]
  STORE TMP
  LOAD A[I+1]
  STORE A[I]
  LOAD TMP
  STORE A[I+1]
  SET SW 1
NO_SWAP:
  INC I
  GOTO INNER
DONE_INNER:
  DEC N
  IF SW EQ 1 GOTO OUTER
PRINT A
HALT
