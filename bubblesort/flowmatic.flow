READ-ITEM A
READ-ITEM N
SET SWAPPED TO 1
LOOP-BEGIN
    COMPARE SWAPPED TO 0
    IF EQUAL GO TO DONE
    SET SWAPPED TO 0
    SET I TO 1
    INNER-LOOP-BEGIN
        COMPARE I TO N-1
        IF GREATER GO TO INNER-DONE
        COMPARE A(I) TO A(I+1)
        IF LESS-OR-EQUAL GO TO NO-SWAP
        TRANSFER A(I) TO TEMP
        TRANSFER A(I+1) TO A(I)
        TRANSFER TEMP TO A(I+1)
        SET SWAPPED TO 1
    NO-SWAP:
        ADD 1 TO I
    INNER-LOOP-END
    INNER-DONE:
    SUBTRACT 1 FROM N
LOOP-END
DONE:
    WRITE-AND-READ-ITEM A
    STOP
