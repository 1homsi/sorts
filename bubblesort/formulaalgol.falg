begin
    integer array arr[1:7] := {64,34,25,12,22,11,90};
    integer n := 7, i, tmp;
    boolean swapped := true;
    while swapped do begin
        swapped := false;
        for i := 1 step 1 until n-1 do
            if arr[i] > arr[i+1] then begin
                tmp := arr[i];
                arr[i] := arr[i+1];
                arr[i+1] := tmp;
                swapped := true
            end;
        n := n - 1
    end;
    for i := 1 step 1 until 7 do
        print(arr[i])
end
