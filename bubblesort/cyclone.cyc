#include <stdio.h>

void bubblesort(int arr[], int n) {
  for (int i = 0; i < n; i++) {
    for (int j = 0; j < n - 1 - i; j++) {
      if (arr[j] > arr[j+1]) {
        int temp = arr[j];
        arr[j] = arr[j+1];
        arr[j+1] = temp;
      }
    }
  }
}

int main() {
  int arr[6] = {5, 2, 8, 1, 9, 3};
  bubblesort(arr, 6);
  for (int i = 0; i < 6; i++) printf("%d ", arr[i]);
  return 0;
}