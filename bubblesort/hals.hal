BUBBLESORT: PROCEDURE (A, SIZE) RETURN (A);
  DECLARE A(SIZE) INTEGER;
  DECLARE SIZE, I, J, TEMP INTEGER;
  FOR I = 1 TO SIZE DO
    FOR J = 1 TO (SIZE - I) DO
      IF A(J) > A(J+1) THEN
      DO;
        TEMP = A(J);
        A(J) = A(J+1);
        A(J+1) = TEMP;
      END;
    END;
  END;
  RETURN A;
END BUBBLESORT;

CALL BUBBLESORT([5, 2, 8, 1, 9, 3], 6);