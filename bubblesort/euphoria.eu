sequence arr
arr = {64, 34, 25, 12, 22, 11, 90}
integer n, i, tmp, swapped

n = length(arr)
swapped = 1
while swapped do
    swapped = 0
    for i = 1 to n - 1 do
        if arr[i] > arr[i+1] then
            tmp = arr[i]
            arr[i] = arr[i+1]
            arr[i+1] = tmp
            swapped = 1
        end if
    end for
    n -= 1
end while

for i = 1 to 7 do
    printf(1, "%d ", arr[i])
end for
puts(1, "\n")
