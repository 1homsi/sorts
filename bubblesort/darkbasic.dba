DIM arr(7)
arr(1)=64 : arr(2)=34 : arr(3)=25 : arr(4)=12
arr(5)=22 : arr(6)=11 : arr(7)=90
n=7
REPEAT
    sw=0
    FOR i=1 TO n-1
        IF arr(i)>arr(i+1)
            t=arr(i) : arr(i)=arr(i+1) : arr(i+1)=t : sw=1
        ENDIF
    NEXT i
    DEC n
UNTIL sw=0
FOR i=1 TO 7
    PRINT arr(i)
NEXT i
WAIT KEY
END
