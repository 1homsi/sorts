process BUBBLE_SORT (in START: event; out DONE: event) =
var
  arr: array[7] of integer := {64, 34, 25, 12, 22, 11, 90},
  n: integer := 7,
  swapped: boolean,
  tmp: integer,
  i: integer
do
  every START do
    loop
      swapped := false;
      i := 0;
      while i < (n - 1) do
        if arr[i] > arr[i+1] then
          tmp := arr[i];
          arr[i] := arr[i+1];
          arr[i+1] := tmp;
          swapped := true
        end;
        i := i + 1
      end;
      n := n - 1;
      if not swapped then
        emit DONE;
        exit
      end
    end
  end
end process
