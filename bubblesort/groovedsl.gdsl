def bubbleSort(arr) {
    def n = arr.size()
    def swapped = true
    while (swapped) {
        swapped = false
        for (int i = 0; i < n - 1; i++) {
            if (arr[i] > arr[i + 1]) {
                def tmp = arr[i]
                arr[i] = arr[i + 1]
                arr[i + 1] = tmp
                swapped = true
            }
        }
        n--
    }
    arr
}

def arr = [64, 34, 25, 12, 22, 11, 90]
println bubbleSort(arr)
