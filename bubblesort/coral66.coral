SECTION 'BSORT'
$INTEGER ARR(7), N, I, TMP
$LOGICAL SWAPPED
$CODE
  ARR(1):=64 ; ARR(2):=34 ; ARR(3):=25 ; ARR(4):=12
  ARR(5):=22 ; ARR(6):=11 ; ARR(7):=90
  N:=7
  SWAPPED:=TRUE
  WHILE SWAPPED DO
    BEGIN
    SWAPPED:=FALSE
    FOR I:=1 STEP 1 UNTIL N-1 DO
      IF ARR(I)>ARR(I+1) THEN
        BEGIN
        TMP:=ARR(I) ; ARR(I):=ARR(I+1) ; ARR(I+1):=TMP
        SWAPPED:=TRUE
        END
    N:=N-1
    END
  FOR I:=1 STEP 1 UNTIL 7 DO PRINT(ARR(I))
$ENDSECTION
