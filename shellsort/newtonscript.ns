shellsort := func(arr) {
  local n, gap, i, j, temp;
  n := length(arr);
  gap := 1;
  while (gap <= n) {
    gap := gap * 3 + 1;
  }
  while (gap > 0) {
    gap := gap / 3;
    i := gap;
    while (i < n) {
      temp := arr[i];
      j := i;
      while (j >= gap && arr[j - gap] > temp) {
        arr[j] := arr[j - gap];
        j := j - gap;
      }
      arr[j] := temp;
      i := i + 1;
    }
  }
  return arr;
};
shellsort([5, 2, 8, 1, 9, 3]);
