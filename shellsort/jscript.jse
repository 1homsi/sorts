function shellsort(arr) {
  var n = arr.length;
  var gap = 1;
  while (gap <= n) gap = gap * 3 + 1;
  while (gap > 0) {
    gap = gap / 3;
    for (var i = gap; i < n; i++) {
      var temp = arr[i];
      var j = i;
      while (j >= gap && arr[j - gap] > temp) {
        arr[j] = arr[j - gap];
        j -= gap;
      }
      arr[j] = temp;
    }
  }
  return arr;
}
WScript.Echo(shellsort([5, 2, 8, 1, 9, 3]));
