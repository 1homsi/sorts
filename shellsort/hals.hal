DECLARE A(6) INITIAL (5, 2, 8, 1, 9, 3);
SHELLSORT: PROCEDURE;
  DECLARE (N, GAP, I, J, TEMP);
  N = 6;
  GAP = 1;
  DO WHILE GAP <= N;
    GAP = GAP * 3 + 1;
  END;
  DO WHILE GAP > 0;
    GAP = GAP / 3;
    DO I = GAP+1 TO N;
      TEMP = A(I);
      J = I;
      DO WHILE J > GAP AND A(J-GAP) > TEMP;
        A(J) = A(J-GAP);
        J = J - GAP;
      END;
      A(J) = TEMP;
    END;
  END;
  PRINT A;
END;
CALL SHELLSORT;
