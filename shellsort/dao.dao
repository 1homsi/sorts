var shellsort = routine( arr ){
  var gap = 1, n = arr.size()
  while( gap <= n ) gap = gap * 3 + 1
  while( gap > 0 ){
    gap = gap / 3
    for( var i = gap; i < n; i++ ){
      var temp = arr[i]
      var j = i
      while( j >= gap && arr[j - gap] > temp ){
        arr[j] = arr[j - gap]
        j -= gap
      }
      arr[j] = temp
    }
  }
  return arr
}
io.writeln( shellsort( [5, 2, 8, 1, 9, 3] ) )
