shell_sort arr:&[i32] n:i32 =
    gap = n / 2
    while gap > 0 do
        i = gap
        while i < n do
            temp = arr[i]
            j = i
            while j >= gap && arr[j - gap] > temp do
                arr[j] = arr[j - gap]
                j -= gap
            arr[j] = temp
            i += 1
        gap /= 2

main () =
    arr = [64, 34, 25, 12, 22, 11, 90]
    shell_sort &arr 7
    print arr
