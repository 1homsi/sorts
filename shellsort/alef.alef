shellsort(a)
  int *a;
{
  int n, gap, i, j, temp;
  n = 6;
  gap = 1;
  while (gap <= n) gap = gap * 3 + 1;
  while (gap > 0) {
    gap = gap / 3;
    for (i = gap; i < n; i++) {
      temp = a[i];
      j = i;
      while (j >= gap && a[j - gap] > temp) {
        a[j] = a[j - gap];
        j -= gap;
      }
      a[j] = temp;
    }
  }
  print(a);
}
main() {
  int a[6];
  a = {5, 2, 8, 1, 9, 3};
  shellsort(a);
}
