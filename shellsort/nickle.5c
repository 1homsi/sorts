auto shellsort = func(arr) {
  auto n = dim(arr);
  auto gap = 1;
  while (gap <= n) gap = gap * 3 + 1;
  while (gap > 0) {
    gap = gap / 3;
    for (auto i = gap; i < n; i++) {
      auto temp = arr[i];
      auto j = i;
      while (j >= gap && arr[j - gap] > temp) {
        arr[j] = arr[j - gap];
        j -= gap;
      }
      arr[j] = temp;
    }
  }
  return arr;
};
shellsort([5, 2, 8, 1, 9, 3]);
