fun shell-sort(arr: vector<int>): vector<int>
  val n = arr.length
  var gap := n / 2
  while { gap > 0 }
    var i := gap
    while { i < n }
      val temp = arr[i]
      var j := i
      while { j >= gap && arr[j - gap] > temp }
        arr[j] := arr[j - gap]
        j := j - gap
      arr[j] := temp
      i := i + 1
    gap := gap / 2
  arr

fun main()
  val arr = vector([64, 34, 25, 12, 22, 11, 90])
  println(shell-sort(arr).list.show)
