DIMENSION arr(7)
arr(1)=64:arr(2)=34:arr(3)=25:arr(4)=12:arr(5)=22:arr(6)=11:arr(7)=90
n=7
gap=INT(n/2)
DO WHILE gap>0
    FOR i=gap+1 TO n
        temp=arr(i)
        j=i
        DO WHILE j>gap .AND. arr(j-gap)>temp
            arr(j)=arr(j-gap)
            j=j-gap
        ENDDO
        arr(j)=temp
    ENDFOR
    gap=INT(gap/2)
ENDDO
FOR i=1 TO n
    ?arr(i)
ENDFOR
