fun shellsort(arr) {
  var gap = 1;
  var n = arr.length;
  while (gap <= n) gap = gap * 3 + 1;
  while (gap > 0) {
    gap = gap / 3;
    for (var i = gap; i < n; i = i + 1) {
      var temp = arr[i];
      var j = i;
      while (j >= gap && arr[j - gap] > temp) {
        arr[j] = arr[j - gap];
        j = j - gap;
      }
      arr[j] = temp;
    }
  }
  return arr;
}
var arr = [5, 2, 8, 1, 9, 3];
print shellsort(arr);
