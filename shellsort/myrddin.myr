const shellsort = {arr : int[:] -> int[:]
  var gap = 1
  var n = arr.len
  while gap <= n
    gap = gap * 3 + 1
  ;;
  while gap > 0
    gap = gap / 3
    for var i = gap; i < n; i++
      var temp = arr[i]
      var j = i
      while j >= gap && arr[j - gap] > temp
        arr[j] = arr[j - gap]
        j -= gap
      ;;
      arr[j] = temp
    ;;
  ;;
  -> arr
}
std.put("{}\n", shellsort([5, 2, 8, 1, 9, 3][:]))
