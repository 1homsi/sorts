shellsort(arr) {
  var n = size(arr);
  var gap = 1;
  while (gap <= n) gap = gap * 3 + 1;
  while (gap > 0) {
    gap = gap / 3;
    for (i in gap..(n - 1)) {
      var temp = arr[i];
      var j = i;
      while (j >= gap && arr[j - gap] > temp) {
        arr[j] = arr[j - gap];
        j -= gap;
      }
      arr[j] = temp;
    }
  }
}
main() {
  shellsort([5, 2, 8, 1, 9, 3]);
}
