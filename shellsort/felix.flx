fun shellsort(arr: array[int]) {
  var gap = 1;
  while (gap <= arr.len()) {
    gap = gap * 3 + 1;
  }
  while (gap > 0) {
    gap = gap / 3;
    for i in gap upto (arr.len() - 1) {
      val temp = arr.i;
      var j = i;
      while (j >= gap && arr.(j - gap) > temp) {
        arr.j := arr.(j - gap);
        j = j - gap;
      }
      arr.j := temp;
    }
  }
  return arr;
}
println$ shellsort(array(5, 2, 8, 1, 9, 3));
