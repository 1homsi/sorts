(let arr [5 2 8 1 9 3])
(let gap 1)
(while (<= gap (len arr))
  (set gap (+ (* gap 3) 1)))
(while (> gap 0)
  (set gap (/ gap 3))
  (for i (range gap (len arr))
    (let temp (at arr i))
    (let j i)
    (while (and (>= j gap) (> (at arr (- j gap)) temp))
      (set (at arr j) (at arr (- j gap)))
      (set j (- j gap)))
    (set (at arr j) temp)))
(print arr)
