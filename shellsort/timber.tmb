class Shellsort {
  def shellsort(arr : Seq[Int]) : Seq[Int] = {
    var gap = 1
    while (gap <= arr.length) gap = gap * 3 + 1
    while (gap > 0) {
      gap = gap / 3
      for (i <- gap until arr.length) {
        var temp = arr(i)
        var j = i
        while (j >= gap && arr(j - gap) > temp) {
          arr(j) = arr(j - gap)
          j -= gap
        }
        arr(j) = temp
      }
    }
    arr
  }
}
val s = new Shellsort()
println(s.shellsort(Seq(5, 2, 8, 1, 9, 3)))
