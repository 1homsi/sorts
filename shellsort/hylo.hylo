public fun shell_sort(_ arr: inout [Int]) {
  let n = arr.count
  var gap = n / 2
  while gap > 0 {
    var i = gap
    while i < n {
      let temp = arr[i]
      var j = i
      while j >= gap && arr[j - gap] > temp {
        &arr[j] = arr[j - gap]
        j -= gap
      }
      &arr[j] = temp
      i += 1
    }
    gap /= 2
  }
}

public fun main() {
  var arr = [64, 34, 25, 12, 22, 11, 90]
  shell_sort(&arr)
  print(arr)
}
