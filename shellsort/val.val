fun shell_sort(arr: mut Array[Int]): Array[Int] {
    let n = arr.count
    var gap = n / 2
    while gap > 0 {
        for i in gap ..< n {
            let temp = arr[i]
            var j = i
            while j >= gap && arr[j - gap] > temp {
                arr[j] = arr[j - gap]
                j -= gap
            }
            arr[j] = temp
        }
        gap /= 2
    }
    arr
}

fun main() {
    var arr = [64, 34, 25, 12, 22, 11, 90]
    print(shell_sort(&arr))
}
