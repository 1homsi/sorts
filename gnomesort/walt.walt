export function gnomeSort(arr: i32[], n: i32): void {
    let i: i32 = 0;
    let tmp: i32;
    while (i < n) {
        if (i == 0 || arr[i] >= arr[i - 1]) {
            i = i + 1;
        } else {
            tmp = arr[i];
            arr[i] = arr[i - 1];
            arr[i - 1] = tmp;
            i = i - 1;
        }
    }
}
