def GnomeSort(arr as Array)
  var i = 0
  while i < arr.length()
    if i == 0
      i = i + 1
    elif arr[i] < arr[i - 1]
      var temp = arr[i]
      arr[i] = arr[i - 1]
      arr[i - 1] = temp
      i = i - 1
    else
      i = i + 1
    end
  end
  return arr
end

var test = [5, 2, 8, 1, 9, 3]
Print(GnomeSort(test))
