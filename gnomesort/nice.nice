int[] gnomesort(int[] arr) {
  int i = 0;
  while (i < arr.length) {
    if (i == 0) {
      i++;
    } else if (arr[i] < arr[i - 1]) {
      int temp = arr[i];
      arr[i] = arr[i - 1];
      arr[i - 1] = temp;
      i--;
    } else {
      i++;
    }
  }
  return arr;
}

void main(String[] args) {
  int[] test = new int[]{5, 2, 8, 1, 9, 3};
  println(gnomesort(test));
}
