public class GnomeSortKey {
    /*@ normal_behavior
      @ requires 0 <= n && n == arr.length;
      @ ensures (\forall int i; 0 <= i && i < n-1; arr[i] <= arr[i+1]);
      @ assignable arr[*];
      @*/
    public static void gnomeSort(int[] arr, int n) {
        int i = 0;
        /*@ loop_invariant 0 <= i && i <= n;
          @ decreases (2 * n - i);
          @ assignable i, arr[*];
          @*/
        while (i < n) {
            if (i == 0 || arr[i] >= arr[i - 1]) {
                i++;
            } else {
                int tmp = arr[i];
                arr[i] = arr[i - 1];
                arr[i - 1] = tmp;
                i--;
            }
        }
    }
}
