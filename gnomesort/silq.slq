def gnomesort(a: uint[]): uint[] {
  uint i = 0;
  while i < length(a) {
    if i == 0 {
      i = i + 1;
    } else if a[i] < a[i-1] {
      uint temp = a[i];
      a[i] = a[i-1];
      a[i-1] = temp;
      i = i - 1;
    } else {
      i = i + 1;
    }
  }
  return a;
}

def main(): uint[] {
  uint[] test = [5, 2, 8, 1, 9, 3];
  return gnomesort(test);
}
