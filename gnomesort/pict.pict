val gnomeSort =
    fun (arr: Array(Int)) (n: Int) : Array(Int) =>
        val i = ref(0) in
        loop {
            if (!i >= n) then break
            else if (!i = 0 || arr[!i] >= arr[!i - 1]) then
                i := !i + 1
            else {
                val tmp = arr[!i] in
                arr[!i] := arr[!i - 1];
                arr[!i - 1] := tmp;
                i := !i - 1
            }
        };
        arr
