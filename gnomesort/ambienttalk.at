def gnomeSort(arr) {
    def i := 0;
    def n := arr.length;
    { i < n }.whileTrue: {
        if: (i == 0).or: { arr[i] >= arr[i - 1] }
        then: { i := i + 1 }
        else: {
            def tmp := arr[i];
            arr[i] := arr[i - 1];
            arr[i - 1] := tmp;
            i := i - 1
        }
    };
    arr
}
