PROGRAM gnomesort;
VAR arr: ARRAY[0..9] OF INTEGER;
    n, i, tmp: INTEGER;
BEGIN
  arr[0]:=5; arr[1]:=3; arr[2]:=8; arr[3]:=1; arr[4]:=9;
  arr[5]:=2; arr[6]:=7; arr[7]:=4; arr[8]:=6; arr[9]:=0;
  n := 10;
  i := 0;
  WHILE i < n DO
    IF (i = 0) OR (arr[i] >= arr[i-1]) THEN
      i := i + 1
    ELSE BEGIN
      tmp := arr[i];
      arr[i] := arr[i-1];
      arr[i-1] := tmp;
      i := i - 1
    END
  END
END.
