function GnomeSort(arr) {
  var i = 0;
  var temp;

  while (i < arr.length) {
    if (i == 0) {
      i++;
    } else if (arr[i] < arr[i - 1]) {
      temp = arr[i];
      arr[i] = arr[i - 1];
      arr[i - 1] = temp;
      i--;
    } else {
      i++;
    }
  }

  return arr;
}

var test = new Array(5, 2, 8, 1, 9, 3);
WScript.Echo(GnomeSort(test));
