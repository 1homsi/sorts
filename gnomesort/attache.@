GnomeSort[arr] := Do[
    n := Size[arr],
    i := 0,
    While[i < n,
        If[Or[i = 0, arr[i] >= arr[i-1]],
            i := i + 1,
            Do[
                tmp := arr[i],
                arr[i] := arr[i-1],
                arr[i-1] := tmp,
                i := i - 1
            ]
        ]
    ],
    arr
]
