proc gnome-sort ptr int -- in
    let arr n in
    0 let i in
    while i n < do
        i 0 = if
            i 1 + let i in
        else
            arr i ptr+ @ arr i 1 - ptr+ @ >= if
                i 1 + let i in
            else
                arr i ptr+ @ let tmp in
                arr i ptr+ arr i 1 - ptr+ @ !
                arr i 1 - ptr+ tmp !
                i 1 - let i in
            end
        end
    end
    end
    end
end
