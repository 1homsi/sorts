module GnomeSort

  use int.Int
  use ref.Ref
  use array.Array

  let gnome_sort (arr : array int) : unit
    ensures { forall i j. 0 <= i < j < Array.length arr -> arr[i] <= arr[j] }
  = let n = Array.length arr in
    let i = ref 0 in
    while !i < n do
      if !i = 0 || arr[!i] >= arr[!i - 1] then
        i := !i + 1
      else begin
        let tmp = arr[!i] in
        arr[!i] <- arr[!i - 1];
        arr[!i - 1] <- tmp;
        i := !i - 1
      end
    done

end
