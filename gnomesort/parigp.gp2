gnome_sort(v) = {
    my(arr = Vec(v), n = #v, i = 1, tmp);
    while(i <= n,
        if(i == 1 || arr[i] >= arr[i-1],
            i++,
            tmp = arr[i];
            arr[i] = arr[i-1];
            arr[i-1] = tmp;
            i--
        )
    );
    arr
}

gnome_sort([5, 3, 8, 1, 9, 2, 7, 4, 6, 0])
