def gnomesort(arr : [Int]) -> [Int] {
  var i : Int = 0
  while (i < arr.length()) {
    if (i == 0) {
      i = i + 1
    } else if (arr[i] < arr[i - 1]) {
      let temp : Int = arr[i]
      arr[i] = arr[i - 1]
      arr[i - 1] = temp
      i = i - 1
    } else {
      i = i + 1
    }
  }
  return arr
}

val test : [Int] = [5, 2, 8, 1, 9, 3]
println(gnomesort(test))
