begin
    integer array a[1:10];
    integer i, n, tmp;
    n := 10;
    i := 1;
    while i <= n do
    begin
        if i = 1 or a[i] >= a[i-1] then
            i := i + 1
        else begin
            tmp := a[i];
            a[i] := a[i-1];
            a[i-1] := tmp;
            i := i - 1
        end
    end
end
