let GnomeSort(arr, n) = value
begin
    let i = 0 ;
    while i < n do begin
        if i = 0 \/ arr[i] >= arr[i-1]
        then i := i + 1
        else begin
            let tmp = arr[i] ;
            arr[i] := arr[i-1] ;
            arr[i-1] := tmp ;
            i := i - 1
        end
    end ;
    arr
end
