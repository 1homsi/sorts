        ARR = ARRAY(10)
        N = 10 : I = 1
        ARR<1> = 5: ARR<2> = 3: ARR<3> = 8: ARR<4> = 1
        ARR<5> = 9: ARR<6> = 2: ARR<7> = 7: ARR<8> = 4
        ARR<9> = 6: ARR<10> = 0
LOOP    GT(I,N) :S(DONE)
        EQ(I,1) :S(ADVANCE)
        GE(ARR<I>,ARR<I - 1>) :S(ADVANCE)
        TEMP = ARR<I>
        ARR<I> = ARR<I - 1>
        ARR<I - 1> = TEMP
        I = I - 1 :(LOOP)
ADVANCE I = I + 1 :(LOOP)
DONE    END
