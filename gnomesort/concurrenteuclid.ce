module GnomeSort
    procedure Sort(var arr: array 0 .. 99 of integer; n: integer)
        var i := 0
        var tmp: integer
        loop
            exit when i >= n
            if i = 0 or arr[i] >= arr[i - 1] then
                i := i + 1
            else
                tmp := arr[i]
                arr[i] := arr[i - 1]
                arr[i - 1] := tmp
                i := i - 1
            end if
        end loop
    end Sort
end GnomeSort
