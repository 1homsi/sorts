routine gnomesort
  read arr
  let i = 0
  do while i < 6
    if i = 0
      let i = i + 1
    else
      if arr[i] < arr[i-1]
        let temp = arr[i]
        let arr[i] = arr[i-1]
        let arr[i-1] = temp
        let i = i - 1
      else
        let i = i + 1
      endif
    endif
  loop
  let test = [5, 2, 8, 1, 9, 3]
  call gnomesort with arr
  print arr
end
