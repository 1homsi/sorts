10 DIM A(10)
20 FOR K = 1 TO 10
30   READ A(K)
40 NEXT K
50 DATA 5,3,8,1,9,2,7,4,6,0
60 I = 1
70 N = 10
80 IF I > N THEN GOTO 160
90 IF I = 1 THEN GOTO 130
100 IF A(I) >= A(I-1) THEN GOTO 130
110 T = A(I): A(I) = A(I-1): A(I-1) = T
120 I = I - 1: GOTO 80
130 I = I + 1
140 GOTO 80
160 FOR K = 1 TO N
170   PRINT A(K)
180 NEXT K
190 END
