func gnomesort(arr: []int): []int {
  i := 0
  {
    i < len(arr)
  } {
    if i == 0 {
      i = i + 1
    } else if arr[i] < arr[i-1] {
      temp := arr[i]
      arr[i] = arr[i-1]
      arr[i-1] = temp
      i = i - 1
    } else {
      i = i + 1
    }
  }
  return arr
}

test := []int{5, 2, 8, 1, 9, 3}
print(gnomesort(test))
