#include "Halide.h"
using namespace Halide;

int main() {
    Buffer<int32_t> arr(10);
    int data[] = {5, 3, 8, 1, 9, 2, 7, 4, 6, 0};
    for (int k = 0; k < 10; k++) arr(k) = data[k];

    int n = 10, i = 0;
    while (i < n) {
        if (i == 0 || arr(i) >= arr(i-1)) {
            i++;
        } else {
            int tmp = arr(i);
            arr(i) = arr(i-1);
            arr(i-1) = tmp;
            i--;
        }
    }
    return 0;
}
