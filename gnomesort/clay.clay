gnomesort(arr: Vector[Int]) {
  var i = 0;
  while (i < size(arr)) {
    if (i == 0) {
      i += 1;
    } else if (arr[i] < arr[i - 1]) {
      var temp = arr[i];
      arr[i] = arr[i - 1];
      arr[i - 1] = temp;
      i -= 1;
    } else {
      i += 1;
    }
  }
  return arr;
}

var test = Vector(5, 2, 8, 1, 9, 3);
println(gnomesort(test));
