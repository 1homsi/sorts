using System;

module GnomeSort {
    public GnomeSort(arr : array[int]) : array[int] {
        mutable i = 0;
        def n = arr.Length;
        while (i < n) {
            if (i == 0 || arr[i] >= arr[i - 1]) {
                i++;
            } else {
                def tmp = arr[i];
                arr[i] = arr[i - 1];
                arr[i - 1] = tmp;
                i--;
            }
        }
        arr
    }
}
