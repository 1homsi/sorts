import * as pulumi from "@pulumi/pulumi";

function gnomeSort(arr: number[]): number[] {
    const a = [...arr];
    let i = 0;
    const n = a.length;
    while (i < n) {
        if (i === 0 || a[i] >= a[i-1]) {
            i++;
        } else {
            [a[i], a[i-1]] = [a[i-1], a[i]];
            i--;
        }
    }
    return a;
}

const sortedArr = gnomeSort([5, 3, 8, 1, 9, 2, 7, 4, 6, 0]);

export const sorted = sortedArr;
