<%
function gnomeSort(arr) {
    const a = [...arr];
    let n = a.length, i = 0;
    while (i < n) {
        if (i === 0 || a[i] >= a[i-1]) i++;
        else { [a[i], a[i-1]] = [a[i-1], a[i]]; i--; }
    }
    return a;
}
const data = [5, 3, 8, 1, 9, 2, 7, 4, 6, 0];
const sorted = gnomeSort(data);
%>
<%= sorted.join(', ') %>
