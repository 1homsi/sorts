component GnomeSort
  export Executable

  gnomesort(arr: ZZ64[]): ZZ64[] = do
    var i: ZZ64 = 0
    while i < |arr| do
      if i = 0 then
        i := i + 1
      else
        if arr[i] < arr[i - 1] then
          temp = arr[i]
          arr[i] := arr[i - 1]
          arr[i - 1] := temp
          i := i - 1
        else
          i := i + 1
        end
      end
    end
    arr
  end

  run(): () = do
    var test: ZZ64[6] = [5, 2, 8, 1, 9, 3]
    println(gnomesort(test))
  end
end
