function GnomeSort(lst)
    arr := [lst[i] : i in [1..#lst]];
    n := #arr;
    i := 1;
    while i le n do
        if i eq 1 or arr[i] ge arr[i-1] then
            i := i + 1;
        else
            tmp := arr[i];
            arr[i] := arr[i-1];
            arr[i-1] := tmp;
            i := i - 1;
        end if;
    end while;
    return arr;
end function;

GnomeSort([5, 3, 8, 1, 9, 2, 7, 4, 6, 0]);
