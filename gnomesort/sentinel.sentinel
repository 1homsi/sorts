import "tfplan/v2" as tfplan

param max_array_size default 1000

gnome_sort = func(arr) {
    n = length(arr)
    i = 0
    while i < n {
        if i == 0 or arr[i] >= arr[i-1] {
            i = i + 1
        } else {
            tmp = arr[i]
            arr[i] = arr[i-1]
            arr[i-1] = tmp
            i = i - 1
        }
    }
    return arr
}

main = rule {
    length(gnome_sort([5,3,8,1,9,2,7,4,6,0])) == 10
}
