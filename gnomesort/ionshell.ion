fn gnome_sort(arr: [int]) -> [int]
    let mut i: int = 0
    let n: int = len(arr)
    while i < n
        if i == 0 || arr[i] >= arr[i - 1]
            i += 1
        else
            let tmp: int = arr[i]
            arr[i] = arr[i - 1]
            arr[i - 1] = tmp
            i -= 1
        end
    end
    arr
end
