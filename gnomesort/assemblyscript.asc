export function gnomeSort(arr: Int32Array): Int32Array {
    const n = arr.length;
    let i = 0;
    while (i < n) {
        if (i === 0 || arr[i] >= arr[i - 1]) {
            i++;
        } else {
            const tmp = arr[i];
            arr[i] = arr[i - 1];
            arr[i - 1] = tmp;
            i--;
        }
    }
    return arr;
}
