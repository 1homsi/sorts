GET "libhdr"

LET gnomesort(arr, n) BE
$(
    LET i = 0
    LET tmp = 0
    WHILE i < n DO
    $(
        IF i = 0 | arr!(i) >= arr!(i-1) THEN
        $(
            i := i + 1
        $)
        ELSE
        $(
            tmp := arr!(i)
            arr!(i) := arr!(i-1)
            arr!(i-1) := tmp
            i := i - 1
        $)
    $)
$)
