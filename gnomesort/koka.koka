fun gnome-sort( arr : vector<int> ) : vector<int>
    val n = arr.length
    var i := 0
    while { i < n }
        if i == 0 || arr[i] >= arr[i - 1] then
            i := i + 1
        else
            val tmp = arr[i]
            arr[i] := arr[i - 1]
            arr[i - 1] := tmp
            i := i - 1
    arr
