- var arr = [5, 3, 8, 1, 9, 2, 7, 4, 6, 0]
- function gnomeSort(arr) {
-   var a = arr.slice()
-   var n = a.length, i = 0
-   while (i < n) {
-     if (i === 0 || a[i] >= a[i-1]) i++
-     else { var t = a[i]; a[i] = a[i-1]; a[i-1] = t; i-- }
-   }
-   return a
- }
- var sorted = gnomeSort(arr)
