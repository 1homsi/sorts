function gnomesort(arr) =
  let
    function helper(i, a) =
      if (i >= length(a))
        then a
      else if (i == 0)
        then helper(i + 1, a)
      else if (a[i] < a[i - 1])
        then helper(i - 1, swap(i, i - 1, a))
      else helper(i + 1, a);

    function swap(i, j, a) =
      [if (k == i)
         then a[j]
       else if (k == j)
         then a[i]
       else a[k] : k in [0:length(a)]];
  in
    helper(0, arr);

test = [5, 2, 8, 1, 9, 3];
print(gnomesort(test));
