module GnomeSort

from "array" include Array

let gnomeSort = (arr) => {
  let n = Array.length(arr)
  let mut i = 0
  while (i < n) {
    if (i == 0 || arr[i] >= arr[i - 1]) {
      i += 1
    } else {
      let tmp = arr[i]
      arr[i] = arr[i - 1]
      arr[i - 1] = tmp
      i -= 1
    }
  }
  arr
}
