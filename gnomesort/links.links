fun gnomeSort(arr) {
    var n = length(arr);
    var i = 0;
    while (i < n) {
        if (i == 0 || arr[i] >= arr[i-1]) {
            i := i + 1
        } else {
            var tmp = arr[i];
            arr[i] := arr[i-1];
            arr[i-1] := tmp;
            i := i - 1
        }
    };
    arr
}
