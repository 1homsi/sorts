gnomesort = proc(arr : array) : array {
  i : int := 0
  while (i < length(arr)) {
    if (i = 0) {
      i := i + 1
    } else {
      if (arr[i] < arr[i - 1]) {
        temp : int := arr[i]
        arr[i] := arr[i - 1]
        arr[i - 1] := temp
        i := i - 1
      } else {
        i := i + 1
      }
    }
  }
  return arr
}

main : unit {
  test : array := [5, 2, 8, 1, 9, 3]
  print(gnomesort(test))
}
