import numpy as np

def gnome_sort(arr):
    arr = arr.copy()
    n = len(arr)
    i = 0
    while i < n:
        if i == 0 or arr[i] >= arr[i-1]:
            i += 1
        else:
            arr[i], arr[i-1] = arr[i-1], arr[i]
            i -= 1
    return arr

data = np.array([5, 3, 8, 1, 9, 2, 7, 4, 6, 0])
result = gnome_sort(data)
print(result)
