GET "libhdr"

LET gnomesort2(arr, n) BE
$(
    LET i = 0
    LET tmp = 0
    UNTIL i >= n DO
    $(
        TEST i = 0 | arr!(i) >= arr!(i-1)
        THEN i +:= 1
        ELSE
        $(
            tmp := arr!(i)
            arr!(i) := arr!(i-1)
            arr!(i-1) := tmp
            i -:= 1
        $)
    $)
$)
