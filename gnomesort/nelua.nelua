local function gnome_sort(arr: span(integer)): span(integer)
    local i = 0
    local n = #arr
    while i < n do
        if i == 0 or arr[i] >= arr[i - 1] then
            i = i + 1
        else
            local tmp = arr[i]
            arr[i] = arr[i - 1]
            arr[i - 1] = tmp
            i = i - 1
        end
    end
    return arr
end
