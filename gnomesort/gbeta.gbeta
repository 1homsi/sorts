gnomeSort:
(# arr: [100] @integer;
   n, i, tmp: @integer;
do
   0 -> i;
   (while i < n repeat
       (if i = 0 or arr[i] >= arr[i-1]
       then i + 1 -> i
       else
           arr[i] -> tmp;
           arr[i-1] -> arr[i];
           tmp -> arr[i-1];
           i - 1 -> i
       if)
   while)
#)
