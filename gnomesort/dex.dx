def gnomesort (arr : n.=>Int) : n.=>Int =
  result = arr
  i = 0
  while i < size result do
    if i == 0
      then i = i + 1
      else if result[i] < result[i - 1]
        then temp = result[i]
             result[i] = result[i - 1]
             result[i - 1] = temp
             i = i - 1
        else i = i + 1

  result

test = [5, 2, 8, 1, 9, 3]
print (gnomesort test)
