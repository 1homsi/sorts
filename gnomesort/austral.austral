module GnomeSort is
    function GnomeSort(arr: Array[Int32], n: Int32): Array[Int32] is
        var i: Int32 := 0;
        while i < n do
            if i = 0 or (arr[i] >= arr[i - 1]) then
                i := i + 1;
            else
                let tmp: Int32 := arr[i];
                arr[i] := arr[i - 1];
                arr[i - 1] := tmp;
                i := i - 1;
            end if;
        end while;
        return arr;
    end;
end module.
