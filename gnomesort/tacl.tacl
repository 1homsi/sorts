?SECTION GNOMESORT
?BLOCK GNOMESORT
>>CALL GNOMESORT_PROC

?BLOCK GNOMESORT_PROC
>>SET I = 0
>>SET ARR = (5 2 8 1 9 3)
>>LABEL SORT_LOOP
>>IF I >= 6 THEN
>>  GOTO SORT_END
>>ENDIF
>>IF I = 0 THEN
>>  SET I = I + 1
>>ELSE
>>  IF ARR[I] < ARR[I - 1] THEN
>>    SET TEMP = ARR[I]
>>    SET ARR[I] = ARR[I - 1]
>>    SET ARR[I - 1] = TEMP
>>    SET I = I - 1
>>  ELSE
>>    SET I = I + 1
>>  ENDIF
>>ENDIF
>>GOTO SORT_LOOP
>>LABEL SORT_END
>>DISPLAY ARR

?END GNOMESORT
