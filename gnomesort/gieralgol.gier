begin
    integer array arr[0:9];
    integer i, n, tmp;
    n := 10;
    i := 0;
    while i < n do begin
        if i = 0 or arr[i] >= arr[i-1] then
            i := i + 1
        else begin
            tmp := arr[i];
            arr[i] := arr[i-1];
            arr[i-1] := tmp;
            i := i - 1
        end
    end
end
