procedure gnome_sort(var arr[1:n]: int; n: int)
    var i: int := 1
    var tmp: int
    do i <= n ->
        if i = 1 or arr[i] >= arr[i-1] ->
            i := i + 1
        [] else ->
            tmp := arr[i]
            arr[i] := arr[i-1]
            arr[i-1] := tmp
            i := i - 1
        fi
    od
end
