procedure gnome_sort(arr)
    local i, n, tmp
    n := *arr
    i := 1
    while i <= n do {
        if i = 1 | arr[i] >= arr[i - 1] then
            i +:= 1
        else {
            tmp := arr[i]
            arr[i] := arr[i - 1]
            arr[i - 1] := tmp
            i -:= 1
        }
    }
    return arr
end
