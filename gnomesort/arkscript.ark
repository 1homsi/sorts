let gnomesort = fun(arr) {
  let i = 0
  {
    i < (len arr)
  } {
    if i == 0 {
      i = i + 1
    } else {
      if (arr[i] < arr[i - 1]) {
        let temp = arr[i]
        arr[i] = arr[i - 1]
        arr[i - 1] = temp
        i = i - 1
      } else {
        i = i + 1
      }
    }
  }
  arr
}

let test = [5 2 8 1 9 3]
(print (gnomesort test))
