.decl input_arr(pos: number, val: number)
.decl sorted_arr(pos: number, val: number)

input_arr(0, 5). input_arr(1, 3). input_arr(2, 8). input_arr(3, 1). input_arr(4, 9).
input_arr(5, 2). input_arr(6, 7). input_arr(7, 4). input_arr(8, 6). input_arr(9, 0).

sorted_arr(rank, val) :-
    input_arr(_, val),
    rank = count : { input_arr(_, v), v < val }.

.output sorted_arr
