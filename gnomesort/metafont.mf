def gnomeSort(expr n) =
  begingroup
  save i, tmp;
  numeric i, tmp;
  i := 1;
  forever:
    exitif i > n;
    if i = 1:
      i := i + 1;
    elseif arr[i] >= arr[i-1]:
      i := i + 1;
    else:
      tmp := arr[i];
      arr[i] := arr[i-1];
      arr[i-1] := tmp;
      i := i - 1;
    fi
  endfor
  endgroup
enddef;

numeric arr[];
arr[1] := 5; arr[2] := 3; arr[3] := 8; arr[4] := 1; arr[5] := 9;
arr[6] := 2; arr[7] := 7; arr[8] := 4; arr[9] := 6; arr[10] := 0;
gnomeSort(10);
end
