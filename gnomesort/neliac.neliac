PROCEDURE GNOMESORT(ARR, N);
BEGIN
    INTEGER I;
    REAL TMP;
    I := 0;
    WHILE I < N DO
    BEGIN
        IF I = 0 OR ARR[I] >= ARR[I-1] THEN
            I := I + 1
        ELSE
        BEGIN
            TMP := ARR[I];
            ARR[I] := ARR[I-1];
            ARR[I-1] := TMP;
            I := I - 1
        END
    END
END;
