module GnomeSort

from "array" include Array

let gnomeSort = (arr) => {
  let n = Array.length(arr)
  let i = ref(0)
  while (i^ < n) {
    if (i^ == 0 || arr[i^] >= arr[i^ - 1]) {
      i := i^ + 1
    } else {
      let tmp = arr[i^]
      arr[i^] = arr[i^ - 1]
      arr[i^ - 1] = tmp
      i := i^ - 1
    }
  }
  arr
}

let data = [> 5, 3, 8, 1, 9, 2, 7, 4, 6, 0]
let sorted = gnomeSort(data)
print(sorted)
