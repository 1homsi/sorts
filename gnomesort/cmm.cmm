gnome_sort(bits32 arr, bits32 n) {
    bits32 i;
    bits32 cur, prv, tmp;
    i = 0;
loop:
    if i >= n goto done;
    if i == 0 goto advance;
    cur = bits32[arr + i * 4];
    prv = bits32[arr + (i-1) * 4];
    if cur >= prv goto advance;
    bits32[arr + i * 4] = prv;
    bits32[arr + (i-1) * 4] = cur;
    i = i - 1;
    goto loop;
advance:
    i = i + 1;
    goto loop;
done:
    return;
}
