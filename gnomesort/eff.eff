effect Gnome = Swap of int * int

let gnomesort arr =
  let rec helper i =
    if i >= Array.length arr then ()
    else if i = 0 then helper (i + 1)
    else if arr.(i) < arr.(i - 1) then (
      let temp = arr.(i) in
      arr.(i) <- arr.(i - 1);
      arr.(i - 1) <- temp;
      helper (i - 1)
    )
    else helper (i + 1)
  in
  helper 0;
  arr

let () =
  let test = [|5; 2; 8; 1; 9; 3|] in
  let _ = gnomesort test in
  Array.iter print_int test
