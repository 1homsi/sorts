var gnomeSort = function(arr) {
    var i = 0;
    var n = arr.length;
    while (i < n) {
        if (i === 0 || arr[i] >= arr[i - 1]) {
            i++;
        } else {
            var tmp = arr[i];
            arr[i] = arr[i - 1];
            arr[i - 1] = tmp;
            i--;
        }
    }
    return arr;
};
