- arr = [5, 3, 8, 1, 9, 2, 7, 4, 6, 0]
- def gnome_sort(arr)
-   a = arr.dup
-   n = a.length
-   i = 0
-   while i < n
-     if i == 0 || a[i] >= a[i-1]
-       i += 1
-     else
-       a[i], a[i-1] = a[i-1], a[i]
-       i -= 1
-     end
-   end
-   a
- end
- sorted = gnome_sort(arr)
%ul
  - sorted.each do |val|
    %li= val
