ACCEPT TEST
PRINT "Enter array: (5 2 8 1 9 3)"

ACCEPT ARR
LOCAL I = 0
LOCAL TEMP = 0
LOCAL N = 6

LABEL SORT
IF I >= N GOTO END
IF I = 0 GOTO SKIP
IF ARR[I] >= ARR[I-1] GOTO SKIP

LOCAL TEMP = ARR[I]
ARR[I] = ARR[I-1]
ARR[I-1] = TEMP
DECREMENT I
GOTO SORT

LABEL SKIP
INCREMENT I
GOTO SORT

LABEL END
PRINT ARR
