proc gnomeSort(intvec lst) {
    intvec arr = lst;
    int n = size(arr);
    int i = 1;
    int tmp;
    while (i <= n) {
        if (i == 1 || arr[i] >= arr[i-1]) {
            i = i + 1;
        } else {
            tmp = arr[i];
            arr[i] = arr[i-1];
            arr[i-1] = tmp;
            i = i - 1;
        }
    }
    return(arr);
}

intvec data = 5, 3, 8, 1, 9, 2, 7, 4, 6, 0;
gnomeSort(data);
