to gnomesort :arr
  local "i 0
  local "j 0
  make "i 0
  while [:i < count :arr] [
    ifelse [:i = 0] [
      make "i (:i + 1)
    ] [
      ifelse [item (:i + 1) :arr < item :i :arr] [
        local "temp 0
        make "temp item (:i + 1) :arr
        setitem (:i + 1) :arr item :i :arr
        setitem :i :arr :temp
        make "i (:i - 1)
      ] [
        make "i (:i + 1)
      ]
    ]
  ]
  output :arr
end

make "test [5 2 8 1 9 3]
print gnomesort :test
