GnomeSort[lst_List] := Module[
    {arr = lst, n = Length[lst], i = 1, tmp},
    While[i <= n,
        Which[
            i == 1, i++,
            arr[[i]] >= arr[[i-1]], i++,
            True,
                tmp = arr[[i]];
                arr[[i]] = arr[[i-1]];
                arr[[i-1]] = tmp;
                i--
        ]
    ];
    arr
]

GnomeSort[{5, 3, 8, 1, 9, 2, 7, 4, 6, 0}]
