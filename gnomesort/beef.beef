namespace GnomeSort
{
    class Program
    {
        static void GnomeSort(int[] arr)
        {
            int i = 0;
            int n = arr.Count;
            while (i < n)
            {
                if (i == 0 || arr[i] >= arr[i - 1])
                    i++;
                else
                {
                    int tmp = arr[i];
                    arr[i] = arr[i - 1];
                    arr[i - 1] = tmp;
                    i--;
                }
            }
        }
    }
}
