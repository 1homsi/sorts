Public Sub GnomeSort(arr As Integer[], n As Integer)
    Dim i As Integer = 0
    Dim tmp As Integer
    While i < n
        If i = 0 Or arr[i] >= arr[i - 1] Then
            i += 1
        Else
            tmp = arr[i]
            arr[i] = arr[i - 1]
            arr[i - 1] = tmp
            i -= 1
        End If
    Wend
End
