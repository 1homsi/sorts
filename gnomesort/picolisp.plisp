(de gnomeSort (Lst)
   (let Arr (apply array Lst)
      (let (N (size Arr)  I 0  Tmp 0)
         (while (< I N)
            (if (or (= I 0) (>= (get Arr (inc I)) (get Arr I)))
               (inc 'I)
               (setq Tmp (get Arr (inc I)))
               (set Arr (inc I) (get Arr I))
               (set Arr I Tmp)
               (dec 'I) ) ) )
      (array->lst Arr) ) )
