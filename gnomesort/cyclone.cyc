#include <core.h>

void gnomesort(int arr[], int len) {
  int i = 0;
  int temp;

  while (i < len) {
    if (i == 0) {
      i++;
    } else if (arr[i] < arr[i - 1]) {
      temp = arr[i];
      arr[i] = arr[i - 1];
      arr[i - 1] = temp;
      i--;
    } else {
      i++;
    }
  }
}

int main() {
  int test[6] = {5, 2, 8, 1, 9, 3};
  gnomesort(test, 6);

  for (int i = 0; i < 6; i++) {
    printf("%d ", test[i]);
  }

  return 0;
}
