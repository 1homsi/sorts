using Flux

function gnome_sort!(arr)
    n = length(arr)
    i = 1
    while i <= n
        if i == 1 || arr[i] >= arr[i-1]
            i += 1
        else
            arr[i], arr[i-1] = arr[i-1], arr[i]
            i -= 1
        end
    end
    return arr
end

data = [5, 3, 8, 1, 9, 2, 7, 4, 6, 0]
gnome_sort!(data)
println(data)
