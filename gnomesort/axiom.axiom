gnomeSort(lst : List Integer) : List Integer ==
    arr : FlexibleArray Integer := flexibleArray lst
    n : Integer := #arr
    i : Integer := 1
    while i <= n repeat
        if i = 1 or arr.i >= arr.(i-1) then
            i := i + 1
        else
            tmp : Integer := arr.i
            arr.i := arr.(i-1)
            arr.(i-1) := tmp
            i := i - 1
    entries arr
