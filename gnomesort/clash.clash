module GnomeSort where

import Clash.Prelude
import Data.List (sortBy)
import Data.Ord (comparing)

gnomeSort :: Vec 10 Int -> Vec 10 Int
gnomeSort = sortBy (comparing id) . toList |> fromList

gnomeSortList :: [Int] -> [Int]
gnomeSortList arr = go arr 0
  where
    n = length arr
    go lst i
      | i >= n = lst
      | i == 0 || lst !! i >= lst !! (i-1) = go lst (i+1)
      | otherwise =
          let (a, x:y:b) = splitAt (i-1) lst
          in go (a ++ y:x:b) (i-1)
