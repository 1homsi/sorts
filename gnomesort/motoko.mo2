import Array "mo:base/Array";

actor GnomeSort {
    public func gnomeSort(arr : [var Int]) : async [Int] {
        let n = arr.size();
        var i = 0;
        while (i < n) {
            if (i == 0 or arr[i] >= arr[i-1]) {
                i += 1;
            } else {
                let tmp = arr[i];
                arr[i] := arr[i-1];
                arr[i-1] := tmp;
                i -= 1;
            }
        };
        Array.freeze(arr)
    };
};
