BEGIN
  INTEGER ARRAY ARR(0:5);
  INTEGER I, TEMP;

  ARR(0) := 5;
  ARR(1) := 2;
  ARR(2) := 8;
  ARR(3) := 1;
  ARR(4) := 9;
  ARR(5) := 3;

  I := 0;
  WHILE I < 6 DO
  BEGIN
    IF I = 0 THEN
      I := I + 1
    ELSE
    BEGIN
      IF ARR(I) < ARR(I - 1) THEN
      BEGIN
        TEMP := ARR(I);
        ARR(I) := ARR(I - 1);
        ARR(I - 1) := TEMP;
        I := I - 1;
      END
      ELSE
        I := I + 1;
    END;
  END;

  FOR I := 0 STEP 1 UNTIL 5 DO
    WRITE(ARR(I));
END.
