int[.] gnomeSortV2(int[.] arr)
{
    n = shape(arr)[0];
    i = 0;
    while (i < n) {
        if (i == 0 || arr[i] >= arr[i-1]) {
            i++;
        } else {
            tmp = arr[i];
            arr[i] = arr[i-1];
            arr[i-1] = tmp;
            i--;
        }
    }
    return arr;
}
