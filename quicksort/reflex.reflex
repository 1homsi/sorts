{-# LANGUAGE OverloadedStrings #-}
module Main where

import Reflex.Dom

quicksort :: Ord a => [a] -> [a]
quicksort [] = []
quicksort (pivot:rest) =
    quicksort [x | x <- rest, x <= pivot]
    ++ [pivot] ++
    quicksort [x | x <- rest, x > pivot]

main :: IO ()
main = mainWidget $ do
    let sorted = quicksort [3, 6, 8, 10, 1, 2, 1 :: Int]
    el "div" $ text $ show sorted
