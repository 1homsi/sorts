prim quicksort : (Array Int) -> Int -> Int -> Unit

val arr = array(7, 0)

let partition arr low high =
  val pivot = arr[high]
  val i = ref low
  for j = low to high-1 do
    if arr[j] <= pivot then
      swap(arr, !i, j)
      i := !i + 1
  arr[!i] <-> arr[high]
  !i

let rec quicksort arr low high =
  if low < high then
    val p = partition arr low high
    quicksort arr low (p-1)
    quicksort arr (p+1) high

run quicksort arr 0 6
