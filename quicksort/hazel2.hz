let rec quicksort = (lst : [Int]) : [Int] =>
  case lst of
  | [] => []
  | [pivot, ...rest] =>
    let left = List.filter((x) => x <= pivot, rest) in
    let right = List.filter((x) => x > pivot, rest) in
    quicksort(left) @ [pivot] @ quicksort(right)

let result = quicksort([3, 6, 8, 10, 1, 2, 1])
