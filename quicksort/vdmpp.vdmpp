class Quicksort

operations

public static sort: seq of int ==> seq of int
sort(lst) ==
    if len lst <= 1 then return lst
    else
        let pivot = lst(len lst div 2)
        in
            return sort([x | x in seq lst & x < pivot]) ^
                   [x | x in seq lst & x = pivot] ^
                   sort([x | x in seq lst & x > pivot]);

end Quicksort
