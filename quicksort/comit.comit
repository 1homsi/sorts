; COMIT - string processing language (1957-1965)
; Quicksort approximation using COMIT's pattern matching
        STARTOVER $
        SETUP $
3/6/8/10/1/2/1 +
        SORT $
$1 -- $2 $3 / $1 <= $2 $/ LESS
$1 -- $2 $3 / $1 > $2 $/ GREATER
LESS    1 SORT $
GREATER SORT 1 $
        OUTPUT $
1 $ PRINT $
        END $
