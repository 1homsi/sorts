\classpath "."

\javaSource "Quicksort.java"

\problem {
    \forall int[] arr;
    \forall int low, high;
    (low >= 0 & high < arr.length & low <= high) ->
    \modifies arr[low..high]
    (
        \forall int i, j;
        (low <= i & i < j & j <= high) ->
        arr[i] <= arr[j]
    )
}

\proof {
    Quicksort.quicksort(arr, low, high)
    RULE: SPLIT_PIVOT
    CASE: left_partition_sorted
    CASE: right_partition_sorted
    QED
}
