method partition(int[] t, int l, int h) : int {
  local int pivot, i, j, tmp
  pivot = t[h]
  i = l
  j = l
  while j < h {
    if t[j] <= pivot {
      tmp = t[i]
      t[i] = t[j]
      t[j] = tmp
      i = i + 1
    }
    j = j + 1
  }
  tmp = t[i]
  t[i] = t[h]
  t[h] = tmp
  return i
}

method quicksort(int[] t, int l, int h) : void {
  local int p
  if l < h {
    p = call partition(t, l, h)
    call quicksort(t, l, p - 1)
    call quicksort(t, p + 1, h)
  }
}
