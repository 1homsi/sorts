function partition(arr: Int32Array, low: i32, high: i32): i32 {
    const pivot = arr[high];
    let i = low;
    for (let j = low; j < high; j++) {
        if (arr[j] <= pivot) {
            const tmp = arr[i];
            arr[i] = arr[j];
            arr[j] = tmp;
            i++;
        }
    }
    const tmp = arr[i];
    arr[i] = arr[high];
    arr[high] = tmp;
    return i;
}

function quicksort(arr: Int32Array, low: i32, high: i32): void {
    if (low < high) {
        const p = partition(arr, low, high);
        quicksort(arr, low, p - 1);
        quicksort(arr, p + 1, high);
    }
}

export function sort(): void {
    const arr = new Int32Array(7);
    arr[0] = 3; arr[1] = 6; arr[2] = 8; arr[3] = 10;
    arr[4] = 1; arr[5] = 2; arr[6] = 1;
    quicksort(arr, 0, 6);
}
