fun quicksort(_ arr: inout Array<Int>, _ low: Int, _ high: Int) {
    guard low < high else { return }
    let p = partition(&arr, low, high)
    quicksort(&arr, low, p - 1)
    quicksort(&arr, p + 1, high)
}

fun partition(_ arr: inout Array<Int>, _ low: Int, _ high: Int) -> Int {
    let pivot = arr[high]
    var i = low
    for j in low ..< high {
        if arr[j] <= pivot {
            arr.swapAt(i, j)
            i += 1
        }
    }
    arr.swapAt(i, high)
    return i
}

var arr = [3, 6, 8, 10, 1, 2, 1]
quicksort(&arr, 0, arr.count - 1)
print(arr)
