quicksort(arr) {
  if (arr.length <= 1) {
    return arr;
  }

  var pivot = arr[0];
  var less = [];
  var greater = [];

  for (var i = 1; i < arr.length; i++) {
    if (arr[i] <= pivot) {
      less.push(arr[i]);
    } else {
      greater.push(arr[i]);
    }
  }

  return quicksort(less) + [pivot] + quicksort(greater);
}

console.log(quicksort([5, 2, 8, 1, 9, 3]));