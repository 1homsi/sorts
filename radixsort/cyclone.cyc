#include <stdio.h>

int* radixsort(int arr[], int n) {
  int max = 0;
  for (int i = 0; i < n; i++) {
    if (arr[i] > max) max = arr[i];
  }
  int exp = 1;
  while (max / exp > 0) {
    exp *= 10;
  }
  return arr;
}

int main() {
  int arr[] = {5, 2, 8, 1, 9, 3};
  int *result = radixsort(arr, 6);
  for (int i = 0; i < 6; i++) {
    printf("%d ", result[i]);
  }
  return 0;
}
