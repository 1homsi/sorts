PREFIX ex: <http://example.org/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?sorted WHERE {
    VALUES ?val { 170 45 75 90 802 24 2 66 }
    BIND(xsd:integer(?val) AS ?v)
    {
        SELECT ?val (GROUP_CONCAT(?val; separator=" ") AS ?sorted) WHERE {
            VALUES ?val { 170 45 75 90 802 24 2 66 }
        }
        GROUP BY ?val
        ORDER BY (xsd:integer(?val) MOD 10) ?val
    }
}
