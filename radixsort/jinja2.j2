RadixSortРєљ{
    РЇх Рєљ РЇх
    РЇЮ Radix sort implementation
    MaxVal Рєљ Рїѕ/РЇх
    Exp Рєљ 1
    :While MaxVal ├и Exp > 0
        РЇх Рєљ CountingSort РЇх Exp
        Exp Рєљ Exp ├Ќ 10
    :EndWhile
    РЇх
}

CountingSortРєљ{
    arr Рєљ РЇ║
    exp Рєљ РЇх
    n Рєљ РЅбarr
    output Рєљ 0РЇ┤arr
    count Рєљ 10РЇ┤0
    count +Рєљ Ріб/{Ріѓ(Рїіarr ├и exp) | 10}┬еРЇ│n
    output Рєљ РіѓРЇњcount
    output
}