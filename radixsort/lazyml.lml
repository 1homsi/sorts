getDigit x exp = (x div exp) mod 10;;

countingSort xs exp =
    concat (map (fn d => filter (fn x => getDigit x exp = d) xs) (upto 0 9));;

upto a b = if a > b then [] else a :: upto (a+1) b;;

radixSortLoop xs maxVal exp =
    if maxVal div exp = 0 then xs
    else radixSortLoop (countingSort xs exp) maxVal (exp * 10);;

radixSort [] = [];;
radixSort xs =
    let maxVal = foldl max 0 xs
    in radixSortLoop xs maxVal 1;;

val result = radixSort [170, 45, 75, 90, 802, 24, 2, 66];;
