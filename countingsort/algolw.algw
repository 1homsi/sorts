BEGIN
  ARRAY ARR[1:6];
  INTEGER MAX, I, J, OUTPUT;
  ARRAY COUNT[0:9];

  ARR[1] := 5;
  ARR[2] := 2;
  ARR[3] := 8;
  ARR[4] := 1;
  ARR[5] := 9;
  ARR[6] := 3;

  MAX := 0;
  FOR I := 1 STEP 1 UNTIL 6 DO
    IF ARR[I] > MAX THEN MAX := ARR[I];

  FOR I := 0 STEP 1 UNTIL 9 DO
    COUNT[I] := 0;

  FOR I := 1 STEP 1 UNTIL 6 DO
    COUNT[ARR[I]] := COUNT[ARR[I]] + 1;

  FOR I := 0 STEP 1 UNTIL 9 DO
    FOR J := 1 STEP 1 UNTIL COUNT[I] DO
      OUTPUT := I;
      WRITE(OUTPUT, " ")
END
