(define $countingsort
  (lambda [$arr]
    (let {[$max (foldl max 0 arr)]
          [$count (make-list (+ max 1) 0)]}
      (let {[$count' (foldl (lambda [$c $x] (update-nth x (+ (nth x c) 1) c)) count arr)]}
        (concatenate (map (lambda [$i] (make-list (nth i count') i)) (range 0 (+ max 1))))))))

(print (countingsort [5 2 8 1 9 3]))
