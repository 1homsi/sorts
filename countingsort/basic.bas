10 DIM A(7), COUNT(100), OUTPUT(7)
20 DATA 4, 2, 2, 8, 3, 3, 1
30 N = 7
40 FOR I = 1 TO N: READ A(I): NEXT I
50 MN = A(1): MX = A(1)
60 FOR I = 2 TO N
70   IF A(I) < MN THEN MN = A(I)
80   IF A(I) > MX THEN MX = A(I)
90 NEXT I
100 RNG = MX - MN + 1
110 FOR I = 0 TO RNG - 1: COUNT(I) = 0: NEXT I
120 FOR I = 1 TO N: COUNT(A(I) - MN) = COUNT(A(I) - MN) + 1: NEXT I
130 FOR I = 1 TO RNG - 1: COUNT(I) = COUNT(I) + COUNT(I - 1): NEXT I
140 FOR I = N TO 1 STEP -1
150   IDX = A(I) - MN
160   COUNT(IDX) = COUNT(IDX) - 1
170   OUTPUT(COUNT(IDX) + 1) = A(I)
180 NEXT I
190 FOR I = 1 TO N: PRINT OUTPUT(I); " ";: NEXT I
200 PRINT
210 END
