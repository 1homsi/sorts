PROC COUNTINGSORT
ARRAY ARR(6)
ARRAY COUNT(10)
ARRAY OUTPUT(6)

ARR(1) = 5
ARR(2) = 2
ARR(3) = 8
ARR(4) = 1
ARR(5) = 9
ARR(6) = 3

MAX = 0
FOR I = 1 TO 6
  IF ARR(I) > MAX THEN
    MAX = ARR(I)
  END IF
NEXT I

FOR I = 0 TO 10
  COUNT(I) = 0
NEXT I

FOR I = 1 TO 6
  COUNT(ARR(I)) = COUNT(ARR(I)) + 1
NEXT I

OUT_IDX = 1
FOR I = 0 TO MAX
  FOR J = 1 TO COUNT(I)
    OUTPUT(OUT_IDX) = I
    OUT_IDX = OUT_IDX + 1
  NEXT J
NEXT I

PRINT OUTPUT

END PROC

CALL COUNTINGSORT
