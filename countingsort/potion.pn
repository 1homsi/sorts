def countingsort(arr):
  if arr == nil:
    return arr
  end

  max = 0
  arr each |val|:
    if val > max:
      max = val
    end
  end

  count = []:copy(max + 1)
  for i in 0..(max + 1):
    count[i] = 0
  end

  arr each |val|:
    count[val] = count[val] + 1
  end

  output = []
  for i in 0..max:
    for j in 0..(count[i]):
      output push(i)
    end
  end

  return output
end

p(countingsort([5, 2, 8, 1, 9, 3]))
