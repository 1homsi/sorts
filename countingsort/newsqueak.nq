fn countingsort(arr: []int): []int {
  if len(arr) == 0 {
    return arr
  }

  max := 0
  for i := 0; i < len(arr); i++ {
    if arr[i] > max {
      max = arr[i]
    }
  }

  count := make([]int, max + 1)
  for i := 0; i < len(arr); i++ {
    count[arr[i]]++
  }

  output := []int{}
  for i := 0; i <= max; i++ {
    for j := 0; j < count[i]; j++ {
      output = append(output, i)
    }
  }

  return output
}

func main() {
  test := []int{5, 2, 8, 1, 9, 3}
  println(countingsort(test))
}
