fun combSort(arr) {
  var gap = arr.length;
  var swapped = true;
  while (gap > 1 || swapped) {
    gap = (gap * 10) / 13;
    if (gap < 1) gap = 1;
    swapped = false;
    for (var i = 0; i < arr.length - gap; i = i + 1) {
      if (arr[i] > arr[i + gap]) {
        var temp = arr[i];
        arr[i] = arr[i + gap];
        arr[i + gap] = temp;
        swapped = true;
      }
    }
  }
  return arr;
}

var sample = [5, 2, 8, 1, 9, 3];
print(combSort(sample));
