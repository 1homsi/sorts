def combSort(List arr) {
    def n = arr.size()
    def gap = n
    def sorted = false
    while (!sorted) {
        gap = (int)(gap / 1.3)
        if (gap <= 1) {
            gap = 1
            sorted = true
        }
        (0..<(n - gap)).each { i ->
            if (arr[i] > arr[i + gap]) {
                def tmp = arr[i]
                arr[i] = arr[i + gap]
                arr[i + gap] = tmp
                sorted = false
            }
        }
    }
    arr
}
