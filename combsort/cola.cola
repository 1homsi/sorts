def comb_sort arr {
  var gap = arr.size
  var swapped = true
  while gap > 1 or swapped {
    gap = (gap * 10) / 13
    if gap < 1 {
      gap = 1
    }
    swapped = false
    for i = 0, i < arr.size - gap, i++ {
      if arr[i] > arr[i + gap] {
        var temp = arr[i]
        arr[i] = arr[i + gap]
        arr[i + gap] = temp
        swapped = true
      }
    }
  }
  return arr
}

var sample = [5, 2, 8, 1, 9, 3]
print(comb_sort(sample))
