combsort :: func(arr: []int) -> []int {
  gap := len(arr)
  swapped := true
  while gap > 1 || swapped {
    gap = (gap * 10) / 13
    if gap < 1 {
      gap = 1
    }
    swapped = false
    for i := 0; i < len(arr) - gap; i++ {
      if arr[i] > arr[i+gap] {
        temp := arr[i]
        arr[i] = arr[i+gap]
        arr[i+gap] = temp
        swapped = true
      }
    }
  }
  return arr
}

sample := []int{5, 2, 8, 1, 9, 3}
print(combsort(sample))
