def comb_sort(arr: list<int>) => list<int>
{
  var gap = arr.size()
  var swapped = true
  while gap > 1 or swapped
  {
    gap = (gap * 10) / 13
    if gap < 1 { gap = 1 }
    swapped = false
    for i in 0 .. (arr.size() - gap - 1)
    {
      if arr[i] > arr[i + gap]
      {
        var temp = arr[i]
        arr[i] = arr[i + gap]
        arr[i + gap] = temp
        swapped = true
      }
    }
  }
  return arr
}

var sample: list<int> = [5, 2, 8, 1, 9, 3]
io.writeln(comb_sort(sample))
