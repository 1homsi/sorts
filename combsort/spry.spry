combSort: func [arr] {
  gap: arr size
  swapped: true
  while [gap > 1 or swapped] {
    gap: (gap * 10) / 13
    if [gap < 1] {gap: 1}
    swapped: false
    i: 0
    while [i < (arr size) - gap] {
      if [arr at: i > arr at: (i + gap)] {
        temp: arr at: i
        arr put: i value: (arr at: (i + gap))
        arr put: (i + gap) value: temp
        swapped: true
      }
      i: i + 1
    }
  }
  return arr
}

sample: #[5 2 8 1 9 3]
print combSort sample
