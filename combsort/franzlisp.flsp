(defun comb-sort (arr)
  (let ((n (length arr))
        (gap (length arr))
        (sorted nil))
    (loop
      (if sorted (return arr))
      (setq gap (max 1 (truncate (/ gap 1.3))))
      (setq sorted (= gap 1))
      (do ((i 0 (1+ i)))
          ((>= (+ i gap) n))
        (when (> (aref arr i) (aref arr (+ i gap)))
          (let ((tmp (aref arr i)))
            (setf (aref arr i) (aref arr (+ i gap)))
            (setf (aref arr (+ i gap)) tmp))
          (setq sorted nil))))))
