to comb_sort :arr
  let "gap (count :arr)
  let "swapped "true
  while :gap > 1 [
    let "gap int (/ :gap 1.3)
    if :gap < 1 [let "gap 1]
    let "i 0
    while :i < (- (count :arr) :gap) [
      if gt (item (+ :i 1) :arr) (item (+ :i :gap 1) :arr) [
        let "temp (item (+ :i 1) :arr)
        setitem (+ :i 1) :arr (item (+ :i :gap 1) :arr)
        setitem (+ :i :gap 1) :arr :temp
      ]
      let "i (+ :i 1)
    ]
  ]
  output :arr
end

let "sample [5 2 8 1 9 3]
print comb_sort :sample
