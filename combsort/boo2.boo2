def combSort(arr as List of int) as List of int:
    n = len(arr)
    gap = n
    sorted = false
    while not sorted:
        gap = int(gap / 1.3)
        if gap <= 1:
            gap = 1
            sorted = true
        for i as int in range(n - gap):
            if arr[i] > arr[i + gap]:
                tmp = arr[i]
                arr[i] = arr[i + gap]
                arr[i + gap] = tmp
                sorted = false
    return arr
