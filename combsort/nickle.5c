void comb_sort(&int[*] arr) {
  int gap = dim(arr);
  int swapped = 1;
  while (gap > 1 || swapped) {
    gap = (gap * 10) / 13;
    if (gap < 1) gap = 1;
    swapped = 0;
    for (int i = 0; i < dim(arr) - gap; i++) {
      if (arr[i] > arr[i + gap]) {
        int temp = arr[i];
        arr[i] = arr[i + gap];
        arr[i + gap] = temp;
        swapped = 1;
      }
    }
  }
}

int[6] sample = {5, 2, 8, 1, 9, 3};
comb_sort(&sample);
for (int i = 0; i < 6; i++)
  printf("%d ", sample[i]);
