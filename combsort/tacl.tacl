?TACL COMB SORT ROUTINE
?SET ARRAY (5 2 8 1 9 3)
?SET GAP 6
?SET SWAPPED 1

:LOOP
?IF [GAP] <= 1
  ?IF [SWAPPED] = 1
    ?SET SWAPPED 0
    ?COMPUTE GAP = [GAP] * 10 / 13
    ?IF [GAP] < 1
      ?SET GAP 1
    ?END
  ?ELSE
    ?GOTO DONE
  ?END
?END

?COMPUTE I = 0
:INNERLOOP
?IF [I] < ([LENGTH OF ARRAY] - [GAP])
  ?IF [ARRAY[I]] > [ARRAY[I + [GAP]]]
    ?SWAP ARRAY[I], ARRAY[I + [GAP]]
    ?SET SWAPPED 1
  ?END
  ?COMPUTE I = [I] + 1
  ?GOTO INNERLOOP
?END

?GOTO LOOP

:DONE
?DISPLAY [ARRAY]
