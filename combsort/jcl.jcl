//COMBSORT JOB (ACCT),'COMB SORT',CLASS=A,MSGCLASS=X
//STEP1    EXEC PGM=IEFBR14
//SYSIN    DD *
  COMB SORT ALGORITHM - JCL DSL REPRESENTATION
  PROCEDURE:
    INITIALIZE GAP = N
    WHILE NOT SORTED:
      COMPUTE GAP = MAX(1, TRUNC(GAP / 1.3))
      IF GAP = 1 SET SORTED = TRUE
      FOR I = 1 TO N - GAP:
        IF ARR(I) > ARR(I+GAP):
          EXCHANGE ARR(I) AND ARR(I+GAP)
          SET SORTED = FALSE
/*
//
