proc comb_sort(var arr: varray[int]) {
  var gap = arr.len();
  var swapped = true;
  while gap > 1 or swapped {
    gap = (gap * 10) / 13;
    if gap < 1 { gap = 1; }
    swapped = false;
    for i in 0usize..arr.len() - gap {
      if arr.(i) > arr.(i + gap) {
        let temp = arr.(i);
        arr.(i) <- arr.(i + gap);
        arr.(i + gap) <- temp;
        swapped = true;
      }
    }
  }
}

var sample = varray[5, 2, 8, 1, 9, 3];
comb_sort(sample);
println$ sample;
