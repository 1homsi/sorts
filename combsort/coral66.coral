ROUTINE COMB_SORT(ARR, N)
  INTEGER ARR(*), N, GAP, I, TMP
  BOOLEAN SORTED
  GAP := N
  SORTED := FALSE
  REPEAT
    GAP := TRUNC(FLOAT(GAP) / 1.3)
    IF GAP < 1 THEN GAP := 1
    IF GAP = 1 THEN SORTED := TRUE
    FOR I := 1 STEP 1 UNTIL N - GAP DO
      IF ARR(I) > ARR(I + GAP) THEN
        TMP := ARR(I)
        ARR(I) := ARR(I + GAP)
        ARR(I + GAP) := TMP
        SORTED := FALSE
      FI
    ROF
  UNTIL SORTED
END
