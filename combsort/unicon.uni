procedure combSort(arr)
    n := *arr
    gap := n
    sorted := &false
    while /sorted do {
        gap := integer(gap / 1.3)
        if gap <= 1 then {
            gap := 1
            sorted := &true
        }
        every i := 1 to n - gap do {
            if arr[i] > arr[i + gap] then {
                tmp := arr[i]
                arr[i] := arr[i + gap]
                arr[i + gap] := tmp
                sorted := &false
            }
        }
    }
    return arr
end
