100 N = 9
110 DIM A(9)
120 A(0)=5:A(1)=3:A(2)=8:A(3)=1:A(4)=9
130 A(5)=2:A(6)=7:A(7)=4:A(8)=6
140 GAP = N
150 SORTED = 0
160 IF SORTED = 1 THEN GOTO 300
170 GAP = INT(GAP / 1.3)
180 IF GAP < 1 THEN GAP = 1
190 IF GAP = 1 THEN SORTED = 1
200 FOR I = 0 TO N - GAP - 1
210   IF A(I) <= A(I + GAP) THEN GOTO 250
220   TMP = A(I)
230   A(I) = A(I + GAP)
240   A(I + GAP) = TMP : SORTED = 0
250 NEXT I
260 GOTO 160
300 END
