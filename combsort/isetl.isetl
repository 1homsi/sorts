comb_sort := func(arr);
    n := #arr;
    gap := n;
    sorted := false;
    while not sorted do
        gap := max(1, floor(gap / 1.3));
        if gap = 1 then sorted := true; end;
        for i in [1..n-gap] do
            if arr(i) > arr(i + gap) then
                tmp := arr(i);
                arr(i) := arr(i + gap);
                arr(i + gap) := tmp;
                sorted := false;
            end;
        end;
    end;
    return arr;
end;
