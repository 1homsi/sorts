comb_sort = |arr|
  gap = arr length
  swapped = 1
  while (gap > 1 or swapped)
    gap = gap * 10 / 13
    if (gap < 1): gap = 1
    swapped = 0
    i = 0
    while (i < arr length - gap)
      if (arr[i] > arr[i + gap]):
        temp = arr[i]
        arr[i] = arr[i + gap]
        arr[i + gap] = temp
        swapped = 1
      i++
  arr

sample = [5, 2, 8, 1, 9, 3]
comb_sort(sample) say
