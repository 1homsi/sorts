10 DIM A(100)
20 N = 10
30 GAP = N
40 SORTED = 0
50 IF SORTED = 1 THEN GOTO 200
60 GAP = INT(GAP / 1.3)
70 IF GAP < 1 THEN GAP = 1
80 NEWSORTED = 1
90 IF GAP = 1 THEN NEWSORTED = 1
100 FOR I = 1 TO N - GAP
110   IF A(I) > A(I + GAP) THEN GOSUB 300
120 NEXT I
130 IF GAP = 1 AND NEWSORTED = 1 THEN SORTED = 1
140 GOTO 50
200 END
300 TMP = A(I)
310 A(I) = A(I + GAP)
320 A(I + GAP) = TMP
330 NEWSORTED = 0
340 RETURN
