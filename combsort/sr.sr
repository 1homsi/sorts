resource CombSort

  procedure combSort(arr[*]: int; n: int)
    var gap := n
    var sorted := false
    var tmp: int
    do not sorted ->
      gap := int(real(gap) / 1.3)
      if gap <= 1 -> gap := 1; sorted := true fi
      fa i := 1 to n - gap ->
        if arr[i] > arr[i+gap] ->
          tmp := arr[i]
          arr[i] := arr[i+gap]
          arr[i+gap] := tmp
          sorted := false
        fi
      af
    od
  end combSort

end CombSort
