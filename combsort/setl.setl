procedure comb_sort(arr);
    n := #arr;
    gap := n;
    sorted := false;
    while not sorted loop
        gap := max(1, floor(gap / 1.3));
        if gap = 1 then sorted := true; end if;
        for i in [1..n-gap] loop
            if arr(i) > arr(i+gap) then
                tmp := arr(i);
                arr(i) := arr(i+gap);
                arr(i+gap) := tmp;
                sorted := false;
            end if;
        end loop;
    end loop;
    return arr;
end procedure;
