combsort = fn(arr) {
  let gap = arr.length
  let swapped = true
  while (gap > 1) or swapped {
    gap = (gap * 10) div 13
    if (gap < 1) then gap = 1
    swapped = false
    for (i = 1 to arr.length - gap) {
      if (arr(i) > arr(i + gap)) then {
        let temp = arr(i)
        arr(i) := arr(i + gap)
        arr(i + gap) := temp
        swapped = true
      }
    }
  }
  arr
}

let sample = [5, 2, 8, 1, 9, 3]
combsort(sample)
