procedure comb_sort(in A : array of int, out B : array of int)
  var gap : int, i : int, j : int
  gap := length(A)

  while gap > 1
    gap := (gap * 10) / 13
    if gap < 1
      gap := 1
    fi

    for i in 0 to length(A) - gap - 1
      j := i + gap
      if A[i] > A[j]
        B[i] <-> B[j]
      fi
    rof
  wend

  B := A
end comb_sort

var arr : array[6] of int
arr[0] := 5
arr[1] := 2
arr[2] := 8
arr[3] := 1
arr[4] := 9
arr[5] := 3
comb_sort(arr, arr)
