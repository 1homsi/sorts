class CombSort
    def sort(arr as int[]) as int[]
        n = arr.length
        gap = n
        sorted = false
        while not sorted
            gap = (gap / 1.3) to int
            if gap <= 1
                gap = 1
                sorted = true
            for i in n - gap
                if arr[i] > arr[i + gap]
                    tmp = arr[i]
                    arr[i] = arr[i + gap]
                    arr[i + gap] = tmp
                    sorted = false
        return arr
