def CombSort(arr: num[]): num[]
  var gap: num = len(arr)
  var swapped: bool = true
  while gap > 1 or swapped
    gap = (gap * 10) / 13
    if gap < 1
      gap = 1
    endif
    swapped = false
    for i in 0..(len(arr) - gap - 1)
      if arr[i] > arr[i + gap]
        var temp: num = arr[i]
        arr[i] = arr[i + gap]
        arr[i + gap] = temp
        swapped = true
      endif
    endfor
  endwhile
  return arr
enddef

var sample: num[] = [5, 2, 8, 1, 9, 3]
print(CombSort(sample))
