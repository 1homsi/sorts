func combSort(mut arr: [Int]) {
  var gap = arr.len()
  var swapped = true
  while gap > 1 || swapped {
    gap = (gap * 10) / 13
    if gap < 1 { gap = 1 }
    swapped = false
    for i in 0..(arr.len() - gap) {
      if arr[i] > arr[i + gap] {
        let temp = arr[i]
        arr[i] = arr[i + gap]
        arr[i + gap] = temp
        swapped = true
      }
    }
  }
}

let sample = [5, 2, 8, 1, 9, 3]
combSort(sample)
println(sample)
