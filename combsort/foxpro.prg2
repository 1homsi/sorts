PROCEDURE CombSort
LPARAMETERS arr, n
LOCAL gap, sorted, i, tmp
gap = n
sorted = .F.
DO WHILE !sorted
    gap = INT(gap / 1.3)
    IF gap <= 1
        gap = 1
        sorted = .T.
    ENDIF
    FOR i = 1 TO n - gap
        IF arr[i] > arr[i + gap]
            tmp = arr[i]
            arr[i] = arr[i + gap]
            arr[i + gap] = tmp
            sorted = .F.
        ENDIF
    NEXT
ENDDO
ENDPROC
