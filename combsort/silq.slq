def comb_sort(arr: int[6]): int[6] {
  var gap: uint = 6;
  var swapped: bool = true;
  while (gap > 1 || swapped) {
    gap = (gap * 10) / 13;
    if (gap < 1) gap = 1;
    swapped = false;
    for i in 0..6 - gap {
      if (arr[i] > arr[i + gap]) {
        var temp: int = arr[i];
        arr[i] = arr[i + gap];
        arr[i + gap] = temp;
        swapped = true;
      }
    }
  }
  return arr;
}

def main() {
  var sample: int[6] = [5, 2, 8, 1, 9, 3];
  print(comb_sort(sample));
}
