def combsort(arr as Array)
  var gap = arr.length()
  var swapped = True
  while gap > 1 or swapped
    gap = int(gap * 10 / 13)
    if gap < 1
      gap = 1
    end
    swapped = False
    var i = 0
    while i < arr.length() - gap
      if arr[i] > arr[i + gap]
        var temp = arr[i]
        arr[i] = arr[i + gap]
        arr[i + gap] = temp
        swapped = True
      end
      i = i + 1
    end
  end
  return arr
end

var sample = [5, 2, 8, 1, 9, 3]
print(combsort(sample))
