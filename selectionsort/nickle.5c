void selection_sort(int a[], int n) {
  for (int i = 0; i < n - 1; i++) {
    int min_idx = i;
    for (int j = i + 1; j < n; j++) {
      if (a[j] < a[min_idx]) {
        min_idx = j;
      }
    }
    int tmp = a[i];
    a[i] = a[min_idx];
    a[min_idx] = tmp;
  }
}

void main() {
  int arr[] = {5, 2, 8, 1, 9, 3};
  selection_sort(arr, 6);
  printf("%d
", arr);
}

main();