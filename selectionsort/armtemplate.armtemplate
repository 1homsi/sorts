{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "variables": {
    "inputArray": [5, 3, 1, 4, 2],
    "sorted": "[sort(variables('inputArray'))]"
  },
  "outputs": {
    "sorted": {
      "type": "array",
      "value": "[variables('sorted')]"
    }
  }
}
