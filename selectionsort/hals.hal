PROGRAM SELECTIONSORT;
DECLARE ARR(6) NUMERIC;
DECLARE N, I, J, MIN_IDX, TMP NUMERIC;

ASSIGN ARR = [5, 2, 8, 1, 9, 3];
ASSIGN N = 6;

FOR I = 1 TO N - 1
  ASSIGN MIN_IDX = I;
  FOR J = I + 1 TO N
    IF ARR[J] < ARR[MIN_IDX] THEN
      ASSIGN MIN_IDX = J;
    END;
  END;
  ASSIGN TMP = ARR[I];
  ASSIGN ARR[I] = ARR[MIN_IDX];
  ASSIGN ARR[MIN_IDX] = TMP;
END;

WRITE ARR;
END SELECTIONSORT;