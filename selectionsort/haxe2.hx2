class SelectionSort2 {
    public static function sort(arr: Array<Int>): Array<Int> {
        var n = arr.length;
        for (i in 0...n) {
            var minIdx = i;
            var j = i + 1;
            while (j < n) {
                if (arr[j] < arr[minIdx]) minIdx = j;
                j++;
            }
            var tmp = arr[i]; arr[i] = arr[minIdx]; arr[minIdx] = tmp;
        }
        return arr;
    }
}
