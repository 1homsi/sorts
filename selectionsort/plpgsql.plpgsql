CREATE OR REPLACE FUNCTION selection_sort(arr integer[]) RETURNS integer[] AS $$
DECLARE
    n integer := array_length(arr, 1);
    min_idx integer;
    tmp integer;
BEGIN
    FOR i IN 1..n-1 LOOP
        min_idx := i;
        FOR j IN i+1..n LOOP
            IF arr[j] < arr[min_idx] THEN
                min_idx := j;
            END IF;
        END LOOP;
        tmp := arr[i];
        arr[i] := arr[min_idx];
        arr[min_idx] := tmp;
    END LOOP;
    RETURN arr;
END;
$$ LANGUAGE plpgsql;
