MODULE ActiveSelSort;
VAR arr: ARRAY 10 OF INTEGER;
    n: INTEGER;

PROCEDURE Sort;
VAR i, j, minIdx, tmp: INTEGER;
BEGIN
    FOR i := 0 TO n - 2 DO
        minIdx := i;
        FOR j := i + 1 TO n - 1 DO
            IF arr[j] < arr[minIdx] THEN minIdx := j END
        END;
        tmp := arr[i]; arr[i] := arr[minIdx]; arr[minIdx] := tmp
    END
END Sort;

BEGIN
    n := 5;
    arr[0] := 5; arr[1] := 3; arr[2] := 1; arr[3] := 4; arr[4] := 2;
    Sort
END ActiveSelSort.
