FUNCTION SelectionSort(arr, n)
    LOCAL i, j, minIdx, tmp
    FOR i = 1 TO n - 1
        minIdx = i
        FOR j = i + 1 TO n
            IF arr[j] < arr[minIdx]
                minIdx = j
            ENDIF
        ENDFOR
        tmp = arr[i]
        arr[i] = arr[minIdx]
        arr[minIdx] = tmp
    ENDFOR
    RETURN arr
ENDFUNC
