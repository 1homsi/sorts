import * as cdk from 'aws-cdk-lib';

function selectionSort(arr: number[]): number[] {
    const n = arr.length;
    for (let i = 0; i < n; i++) {
        let minIdx = i;
        for (let j = i + 1; j < n; j++) {
            if (arr[j] < arr[minIdx]) minIdx = j;
        }
        [arr[i], arr[minIdx]] = [arr[minIdx], arr[i]];
    }
    return arr;
}

const app = new cdk.App();
console.log(selectionSort([5, 3, 1, 4, 2]));
