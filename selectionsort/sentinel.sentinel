import "tfplan/v2" as tfplan

selection_sort = func(arr) {
    n = length(arr)
    result = arr
    for i in range(0, n) {
        min_idx = i
        for j in range(i + 1, n) {
            if result[j] < result[min_idx] {
                min_idx = j
            }
        }
        tmp = result[i]
        result[i] = result[min_idx]
        result[min_idx] = tmp
    }
    return result
}

main = rule {
    selection_sort([5, 3, 1, 4, 2]) == [1, 2, 3, 4, 5]
}
