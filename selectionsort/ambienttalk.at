def selectionSort(arr) {
    def n := arr.length;
    def i := 0;
    { i < n }.whileTrue: {
        def minIdx := i;
        def j := i + 1;
        { j < n }.whileTrue: {
            if: (arr[j] < arr[minIdx]) then: { minIdx := j };
            j := j + 1
        };
        def tmp := arr[i];
        arr[i] := arr[minIdx];
        arr[minIdx] := tmp;
        i := i + 1
    };
    arr
}
