@{
    var arr = new int[] { 5, 3, 1, 4, 2 };
    int n = arr.Length;
    for (int i = 0; i < n; i++) {
        int minIdx = i;
        for (int j = i + 1; j < n; j++) {
            if (arr[j] < arr[minIdx]) minIdx = j;
        }
        int tmp = arr[i]; arr[i] = arr[minIdx]; arr[minIdx] = tmp;
    }
}
<ul>
@foreach (var val in arr) {
    <li>@val</li>
}
</ul>
