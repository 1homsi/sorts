local selection_sort := func(arr) {
  local n := length(arr);
  for (local i := 0; i < n - 1; i := i + 1) {
    local min_idx := i;
    for (local j := i + 1; j < n; j := j + 1) {
      if (arr[j] < arr[min_idx]) {
        min_idx := j;
      };
    };
    local tmp := arr[i];
    arr[i] := arr[min_idx];
    arr[min_idx] := tmp;
  };
  return arr;
};

print(selection_sort([5, 2, 8, 1, 9, 3]));