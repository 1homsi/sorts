library(tidyverse)

selection_sort <- function(arr) {
  n <- length(arr)
  for (i in seq_len(n - 1)) {
    min_idx <- i
    for (j in (i + 1):n) {
      if (arr[j] < arr[min_idx]) min_idx <- j
    }
    tmp <- arr[i]; arr[i] <- arr[min_idx]; arr[min_idx] <- tmp
  }
  arr
}

result <- selection_sort(c(5, 3, 1, 4, 2))
cat(result, "\n")
