type SortedArray = (u8, u8, u8, u8, u8);

fn selection_sort(arr: [u8; 5]) -> [u8; 5] {
    let mut result = arr;
    for i in 0..5 {
        let mut min_idx = i;
        for j in i+1..5 {
            if result[j] < result[min_idx] {
                min_idx = j;
            }
        }
        let tmp = result[i];
        result[i] = result[min_idx];
        result[min_idx] = tmp;
    }
    result
}
