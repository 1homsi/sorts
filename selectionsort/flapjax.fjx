var selectionSort = function(arr) {
    var n = arr.length;
    for (var i = 0; i < n; i++) {
        var minIdx = i;
        for (var j = i + 1; j < n; j++) {
            if (arr[j] < arr[minIdx]) minIdx = j;
        }
        var tmp = arr[i]; arr[i] = arr[minIdx]; arr[minIdx] = tmp;
    }
    return arr;
};
