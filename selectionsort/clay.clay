selectionSort(arr:Vector[Int]) {
    var n = size(arr);
    for (i in range(n - 1)) {
        var minIdx = i;
        for (j in range(i + 1, n)) {
            if (arr[j] < arr[minIdx]) {
                minIdx = j;
            }
        }
        var tmp = arr[i];
        arr[i] = arr[minIdx];
        arr[minIdx] = tmp;
    }
    return arr;
}

println(selectionSort([5, 2, 8, 1, 9, 3]));