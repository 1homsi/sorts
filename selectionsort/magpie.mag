fn selectionSort(arr Array<Number>) Array<Number>
  var n = arr count
  for i = 0; i < n - 1; i = i + 1
    var minIdx = i
    for j = i + 1; j < n; j = j + 1
      if arr at(j) < arr at(minIdx)
        minIdx = j
      end
    end
    var tmp = arr at(i)
    arr set(i, arr at(minIdx))
    arr set(minIdx, tmp)
  end
  return arr
end

print(selectionSort([5, 2, 8, 1, 9, 3]))