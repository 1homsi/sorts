<?php
$arr = [5, 3, 1, 4, 2];
$n = count($arr);
for ($i = 0; $i < $n; $i++) {
    $minIdx = $i;
    for ($j = $i + 1; $j < $n; $j++) {
        if ($arr[$j] < $arr[$minIdx]) $minIdx = $j;
    }
    [$arr[$i], $arr[$minIdx]] = [$arr[$minIdx], $arr[$i]];
}
?>
<ul>
@foreach ($arr as $val)
    <li>{{ $val }}</li>
@endforeach
</ul>
