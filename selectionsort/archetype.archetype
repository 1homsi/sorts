archetype selection_sort

variable arr : list<int> = [5; 3; 1; 4; 2]

function sort(lst : list<int>) : list<int> {
    match lst with
    | [] -> []
    | _ ->
        let m = List.fold_left (fun acc x -> if x < acc then x else acc) (List.head lst) lst in
        cons(m, sort(List.filter (fun x -> x <> m) lst))
    end
}

entry run() {
    arr := sort(arr)
}
