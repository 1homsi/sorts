program selection_sort;
    arr := [5, 3, 1, 4, 2];
    n := #arr;
    for i in [1..n-1] loop
        min_idx := i;
        for j in [i+1..n] loop
            if arr(j) < arr(min_idx) then
                min_idx := j;
            end if;
        end loop;
        tmp := arr(i);
        arr(i) := arr(min_idx);
        arr(min_idx) := tmp;
    end loop;
    print(arr);
end program;
