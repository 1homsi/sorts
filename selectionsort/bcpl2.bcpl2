GET "libhdr"

LET selectionSort(arr, n) BE
$(
    LET i, j, minIdx, tmp = 0, 0, 0, 0
    FOR i = 0 TO n - 2 DO
    $(
        minIdx := i
        FOR j = i + 1 TO n - 1 DO
            IF arr!j < arr!minIdx THEN minIdx := j
        tmp := arr!i
        arr!i := arr!minIdx
        arr!minIdx := tmp
    $)
$)
