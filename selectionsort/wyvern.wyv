def selectionSort(arr: Array[Int]): Array[Int]
    val n = arr.length
    var i = 0
    while (i < n)
        var minIdx = i
        var j = i + 1
        while (j < n)
            if arr(j) < arr(minIdx)
                minIdx = j
            j = j + 1
        val tmp = arr(i)
        arr(i) = arr(minIdx)
        arr(minIdx) = tmp
        i = i + 1
    arr
