fun selectionSort(arr) {
  var n = arr.size();
  for (var i = 0; i < n - 1; i = i + 1) {
    var minIdx = i;
    for (var j = i + 1; j < n; j = j + 1) {
      if (arr[j] < arr[minIdx]) {
        minIdx = j;
      }
    }
    var tmp = arr[i];
    arr[i] = arr[minIdx];
    arr[minIdx] = tmp;
  }
  return arr;
}

print(selectionSort([5, 2, 8, 1, 9, 3]));