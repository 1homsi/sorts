module SelectionSort {
    field F;
    
    function sort(arr: [F; 5]) -> [F; 5] {
        var result = arr;
        for i in 0..5 {
            var min_idx = i;
            for j in i+1..5 {
                if result[j] < result[min_idx] {
                    min_idx = j;
                }
            }
            var tmp = result[i];
            result[i] = result[min_idx];
            result[min_idx] = tmp;
        }
        return result;
    }
}
