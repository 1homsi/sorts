define selection_sort(arr)
    lvars n = length(arr), i, j, min_idx, tmp
    repeat n-1 times
        i => min_idx
        repeat (i:=0; i < n-1; i:=i+1) times
            if arr(j) < arr(min_idx) then
                j => min_idx
            endif
        endrepeat
        arr(i) => tmp
        arr(min_idx) => arr(i)
        tmp => arr(min_idx)
    endrepeat
    arr
enddefine

print(selection_sort([5, 2, 8, 1, 9, 3]))