define selection_sort(arr[], n) {
    auto i, j, min_idx, tmp
    for (i = 0; i < n; i++) {
        min_idx = i
        for (j = i + 1; j < n; j++) {
            if (arr[j] < arr[min_idx]) min_idx = j
        }
        tmp = arr[i]
        arr[i] = arr[min_idx]
        arr[min_idx] = tmp
    }
    return(0)
}
