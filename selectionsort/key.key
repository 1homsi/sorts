\problem {
    \programVariables {
        int[] arr;
        int n, i, j, minIdx, tmp;
    }
    \program {
        for (i = 0; i < n - 1; i++) {
            minIdx = i;
            for (j = i + 1; j < n; j++) {
                if (arr[j] < arr[minIdx]) minIdx = j;
            }
            tmp = arr[i];
            arr[i] = arr[minIdx];
            arr[minIdx] = tmp;
        }
    }
    \formula {
        \forall int i; \forall int j; (0 <= i & i < j & j < n -> arr[i] <= arr[j])
    }
}
