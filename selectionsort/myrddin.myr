use std

const selectionSort = {arr : int[:] -> int[:]
    let n = arr.len
    for var i = 0; i < n - 1; ++i
        var minIdx = i
        for var j = i + 1; j < n; ++j
            if arr[j] < arr[minIdx]
                minIdx = j
            ;;
        ;;
        (arr[i], arr[minIdx]) = (arr[minIdx], arr[i])
    ;;
    -> arr
}

const main = {
    std.put("Sorted: {}
", selectionSort(std.slalloc([5, 2, 8, 1, 9, 3][:][:])))
}