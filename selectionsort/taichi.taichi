import taichi as ti

ti.init(arch=ti.cpu)

@ti.func
def selection_sort(arr: ti.template(), n: int):
    for i in range(n):
        min_idx = i
        for j in range(i + 1, n):
            if arr[j] < arr[min_idx]:
                min_idx = j
        tmp = arr[i]
        arr[i] = arr[min_idx]
        arr[min_idx] = tmp

data = ti.field(dtype=ti.i32, shape=5)
data[0], data[1], data[2], data[3], data[4] = 5, 3, 1, 4, 2

@ti.kernel
def main():
    selection_sort(data, 5)

main()
