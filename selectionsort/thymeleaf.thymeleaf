<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<body>
<ul>
  <li th:each="val : ${sorted}" th:text="${val}"></li>
</ul>
<script th:inline="javascript">
  var arr = [5, 3, 1, 4, 2];
  var n = arr.length;
  for (var i = 0; i < n; i++) {
    var minIdx = i;
    for (var j = i + 1; j < n; j++) {
      if (arr[j] < arr[minIdx]) minIdx = j;
    }
    var tmp = arr[i]; arr[i] = arr[minIdx]; arr[minIdx] = tmp;
  }
</script>
</body>
</html>
