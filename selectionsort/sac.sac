use Array: all;
use StdIO: all;

int[*] selectionSort(int[*] arr)
{
    n = shape(arr)[0];
    res = arr;
    for (i = 0; i < n-1; i++) {
        min_idx = i;
        for (j = i+1; j < n; j++) {
            if (res[j] < res[min_idx]) {
                min_idx = j;
            }
        }
        tmp = res[i];
        res[i] = res[min_idx];
        res[min_idx] = tmp;
    }
    return res;
}
