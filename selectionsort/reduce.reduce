procedure selectionSort(arr, n);
begin
    integer i, j, minIdx, tmp;
    for i := 1 step 1 until n-1 do begin
        minIdx := i;
        for j := i+1 step 1 until n do
            if arr(j) < arr(minIdx) then minIdx := j;
        tmp := arr(i);
        arr(i) := arr(minIdx);
        arr(minIdx) := tmp
    end
end;
