procedure selection_sort(arr: array[int], n: int):
    i := 0
    while i < n:
        min_idx := i
        j := i + 1
        while j < n:
            if arr[j] < arr[min_idx]:
                min_idx := j
            j := j + 1
        tmp := arr[i]
        arr[i] := arr[min_idx]
        arr[min_idx] := tmp
        i := i + 1
    return
