def selectionSort(arr : array[int]) : array[int] {
    val n = arr.size;
    for (i <- 0 until n - 1) {
        var minIdx = i;
        for (j <- i + 1 until n) {
            if (arr[j] < arr[minIdx]) {
                minIdx = j;
            }
        }
        val tmp = arr[i];
        arr[i] = arr[minIdx];
        arr[minIdx] = tmp;
    }
    arr;
}

selectionSort(array(5, 2, 8, 1, 9, 3)).toString();