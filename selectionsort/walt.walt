function selectionSort(arr: i32*, n: i32): void {
    let i: i32 = 0;
    while (i < n) {
        let minIdx: i32 = i;
        let j: i32 = i + 1;
        while (j < n) {
            if (arr[j] < arr[minIdx]) {
                minIdx = j;
            }
            j = j + 1;
        }
        let tmp: i32 = arr[i];
        arr[i] = arr[minIdx];
        arr[minIdx] = tmp;
        i = i + 1;
    }
}
