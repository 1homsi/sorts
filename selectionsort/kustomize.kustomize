apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
resources:
  - deployment.yaml
patches:
  - target:
      kind: ConfigMap
      name: sort-config
    patch: |-
      - op: replace
        path: /data/algorithm
        value: selection-sort
configMapGenerator:
  - name: sort-data
    literals:
      - input=5,3,1,4,2
      - algorithm=selection-sort
