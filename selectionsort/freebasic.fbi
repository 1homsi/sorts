Dim arr(1 To 5) As Integer = {5, 3, 1, 4, 2}
Dim n As Integer = 5
Dim i As Integer, j As Integer, minIdx As Integer, tmp As Integer
For i = 1 To n - 1
    minIdx = i
    For j = i + 1 To n
        If arr(j) < arr(minIdx) Then minIdx = j
    Next j
    tmp = arr(i): arr(i) = arr(minIdx): arr(minIdx) = tmp
Next i
For i = 1 To n
    Print arr(i)
Next i
End
