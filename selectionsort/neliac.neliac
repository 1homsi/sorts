begin
    integer array arr[0:9];
    integer n, i, j, minIdx, tmp;
    n := 5;
    arr[0] := 5; arr[1] := 3; arr[2] := 1; arr[3] := 4; arr[4] := 2;
    for i := 0 step 1 until n-2 do
    begin
        minIdx := i;
        for j := i+1 step 1 until n-1 do
            if arr[j] < arr[minIdx] then minIdx := j;
        tmp := arr[i];
        arr[i] := arr[minIdx];
        arr[minIdx] := tmp
    end
end
