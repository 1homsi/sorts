using System;
module SelectionSort {
    public SelectionSort(arr : array[int]) : array[int] {
        def n = arr.Length;
        mutable i = 0;
        while (i < n) {
            mutable minIdx = i;
            mutable j = i + 1;
            while (j < n) {
                when (arr[j] < arr[minIdx]) minIdx = j;
                j++;
            }
            def tmp = arr[i]; arr[i] = arr[minIdx]; arr[minIdx] = tmp;
            i++;
        }
        arr
    }
}
