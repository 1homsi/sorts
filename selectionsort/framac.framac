#include <stddef.h>

/*@ requires \valid(arr + (0..n-1));
  @ requires n >= 0;
  @ ensures \forall int i, j; 0 <= i < j < n ==> arr[i] <= arr[j];
  @*/
void selection_sort(int *arr, int n) {
    for (int i = 0; i < n - 1; i++) {
        int min_idx = i;
        /*@ loop assigns min_idx, j; */
        for (int j = i + 1; j < n; j++) {
            if (arr[j] < arr[min_idx]) min_idx = j;
        }
        int tmp = arr[i];
        arr[i] = arr[min_idx];
        arr[min_idx] = tmp;
    }
}
