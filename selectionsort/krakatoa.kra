class SelectionSort {
    /*@ requires arr != null && arr.length >= 0
      @ ensures \forall int i,j; 0 <= i < j < arr.length ==> arr[i] <= arr[j]
      @*/
    static void sort(int[] arr) {
        int n = arr.length;
        for (int i = 0; i < n; i++) {
            int minIdx = i;
            for (int j = i + 1; j < n; j++) {
                if (arr[j] < arr[minIdx]) minIdx = j;
            }
            int tmp = arr[i]; arr[i] = arr[minIdx]; arr[minIdx] = tmp;
        }
    }
}
