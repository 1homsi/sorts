fn cocktailsort(mut arr: [Int]) -> [Int] {
    let n = arr.size()
    var i = 0
    while i < n {
        var swapped = false
        for k in 0 .. n - i - 2 {
            if arr[k] > arr[k + 1] {
                let temp = arr[k]
                arr[k] = arr[k + 1]
                arr[k + 1] = temp
                swapped = true
            }
        }
        if not swapped then break
        i = i + 1
    }
    arr
}

var arr = [5, 2, 8, 1, 9, 3]
print(cocktailsort(arr))
