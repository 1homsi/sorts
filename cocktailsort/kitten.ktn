define cocktailsort (array :array -> array):
  dup length -> n;
  0 -> i;
  {
    i n < {
      false -> swapped;
      0 -> k;
      {
        k n i - 1 - < {
          k 1 + k array index-of -> (val1);
          k array index-of -> (val2);
          val2 val1 > {
            k 1 + k array swap -> array;
            true -> swapped;
          } if;
          k 1 + -> k;
        } while;
      };
      swapped not { break } if;
      i 1 + -> i;
    } while;
  };
  array;
