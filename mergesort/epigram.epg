merge :: List Nat -> List Nat -> List Nat;
merge [] ys = ys;
merge xs [] = xs;
merge (x:xs) (y:ys) = if x <= y then x:(merge xs (y:ys)) else y:(merge (x:xs) ys);

mergesort :: List Nat -> List Nat;
mergesort [] = [];
mergesort [x] = [x];
mergesort xs = let mid = length xs / 2;
               let l = take mid xs;
               let r = drop mid xs;
            in merge (mergesort l) (mergesort r);

main = print (mergesort [5,2,8,1,9,3]);
