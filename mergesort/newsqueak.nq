merge := fn(arr, left, mid, right) {
  i := left;
  j := mid + 1;
  result := [];
  
  while (i <= mid && j <= right) {
    if (arr[i] <= arr[j]) {
      result = result + [arr[i]];
      i++;
    } else {
      result = result + [arr[j]];
      j++;
    }
  }
  
  while (i <= mid) {
    result = result + [arr[i]];
    i++;
  }
  
  while (j <= right) {
    result = result + [arr[j]];
    j++;
  }
  
  for (k := 0; k < len(result); k++) {
    arr[left + k] = result[k];
  }
};

mergesort := fn(arr, left, right) {
  if (left < right) {
    mid := (left + right) / 2;
    mergesort(arr, left, mid);
    mergesort(arr, mid + 1, right);
    merge(arr, left, mid, right);
  }
};

arr := [5, 2, 8, 1, 9, 3];
mergesort(arr, 0, 5);
print(arr);
