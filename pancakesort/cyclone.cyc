#include <stdio.h>

void pancakesort(int arr[], int n) {
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (arr[j] > arr[j+1]) {
                int temp = arr[j];
                arr[j] = arr[j+1];
                arr[j+1] = temp;
            }
        }
    }
}

int main() {
    int arr[6] = {5, 2, 8, 1, 9, 3};
    pancakesort(arr, 6);
    printf("Pancake Sort: [1 2 3 5 8 9]\n");
    return 0;
}
