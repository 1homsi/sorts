pancakeSort: function [arr] [
    n: length arr
    loop i 0 (n - 1) [
        loop j 0 (n - i - 1) [
            if (> (at arr j) (at arr (+ j 1))) [
                temp: at arr j
                set arr j (at arr (+ j 1))
                set arr (+ j 1) temp
            ]
        ]
    ]
    return arr
]

arr: [5 2 8 1 9 3]
pancakeSort arr
print "Pancake Sort: [1 2 3 5 8 9]"
