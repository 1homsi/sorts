pancakesort := fn(arr) {
    n := len(arr);
    for i := 0; i < n - 1; i++ {
        for j := 0; j < n - i - 1; j++ {
            if arr[j] > arr[j+1] {
                temp := arr[j];
                arr[j] = arr[j+1];
                arr[j+1] = temp;
            }
        }
    }
    arr
};

arr := array[6] of {5, 2, 8, 1, 9, 3};
print("Pancake Sort: ", pancakesort(arr), "\n");
