10 DIM A(6)
20 A(0)=3:A(1)=6:A(2)=2:A(3)=7:A(4)=4:A(5)=1:A(6)=5
30 N=7:S=N
40 IF S<=1 THEN GOTO 120
50 M=0
60 FOR I=1 TO S-1
70 IF A(I)>A(M) THEN M=I
80 NEXT I
90 IF M=S-1 THEN GOTO 110
100 IF M<>0 THEN GOSUB 130: REM FLIP M
101 K=S-1:GOSUB 130
110 S=S-1:GOTO 40
120 FOR I=0 TO N-1:PRINT A(I);" ";:NEXT I:PRINT:END
130 L=0:R=K
140 IF L>=R THEN RETURN
150 T=A(L):A(L)=A(R):A(R)=T
160 L=L+1:R=R-1:GOTO 140
