const pancakesort = {arr : int[:] -> void
    for var i = 0; i < arr.len() - 1; i++ {
        for var j = 0; j < arr.len() - i - 1; j++ {
            if arr[j] > arr[j+1] {
                (arr[j], arr[j+1]) = (arr[j+1], arr[j])
            }
        }
    }
}

const main = {
    var arr = [5, 2, 8, 1, 9, 3][:]
    pancakesort(arr)
    std.put("Pancake Sort: ")
    std.putv(arr)
}
