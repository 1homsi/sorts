export Executable
run() {
    arr = [5, 2, 8, 1, 9, 3]
    n = |arr|
    
    for i <- 0:n-1 do
        for j <- 0:n-i-1 do
            if arr[j] > arr[j+1] then
                temp = arr[j]
                arr[j] := arr[j+1]
                arr[j+1] := temp
            end
        end
    end
    
    println("Pancake Sort: " arr)
}
