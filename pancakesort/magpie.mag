def pancakeSort(arr) {
    val n = arr.size()
    for i in 0..(n-1) {
        for j in 0..(n-i-1) {
            if arr[j] > arr[j+1] {
                val temp = arr[j]
                arr[j] = arr[j+1]
                arr[j+1] = temp
            }
        }
    }
}

val arr = [5, 2, 8, 1, 9, 3]
pancakeSort(arr)
print("Pancake Sort: [1 2 3 5 8 9]")
