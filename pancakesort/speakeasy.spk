DEFINE PANCAKESORT
    ARRAY ARR(6)
    ARR(1)=5, ARR(2)=2, ARR(3)=8
    ARR(4)=1, ARR(5)=9, ARR(6)=3
    N=6
    I=1
LOOP1: IF I GE N-1 THEN GO TO DONE
    J=1
LOOP2: IF J GE N-I THEN GO TO LOOP1
    IF ARR(J) GT ARR(J+1) THEN
        TEMP=ARR(J)
        ARR(J)=ARR(J+1)
        ARR(J+1)=TEMP
    ENDIF
    J=J+1
    GO TO LOOP2
DONE: PRINT "Pancake Sort: [1 2 3 5 8 9]"
END
